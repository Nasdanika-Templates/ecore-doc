:1},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&quot;id&quot;:&quot;UIFeature@https://nasdanika.org/models/ui&quot;,&quot;name&quot;:&quot;UIFeature&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/UIFeature/index.html&quot;},&quot;x&quot;:591.5447926987754,&quot;y&quot;:437.68050333988975,&quot;category&quot;:1},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&quot;id&quot;:&quot;Output@https://nasdanika.org/models/ui&quot;,&quot;name&quot;:&quot;Output&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/Output/index.html&quot;},&quot;x&quot;:819.0058701169903,&quot;y&quot;:413.6995613018858,&quot;category&quot;:1},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&quot;id&quot;:&quot;UIElement@https://nasdanika.org/models/ui&quot;,&quot;name&quot;:&quot;UIElement&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/UIElement/index.html&quot;},&quot;x&quot;:570.1120599145032,&quot;y&quot;:259.02304198909604,&quot;category&quot;:1},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&quot;id&quot;:&quot;UIGroup@https://nasdanika.org/models/ui&quot;,&quot;name&quot;:&quot;UIGroup&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/UIGroup/index.html&quot;},&quot;x&quot;:703.9416500224644,&quot;y&quot;:154.96073342746948,&quot;category&quot;:1},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EEnum.gif&quot;,&quot;id&quot;:&quot;GroupStyle@https://nasdanika.org/models/ui&quot;,&quot;name&quot;:&quot;GroupStyle&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/GroupStyle/index.html&quot;},&quot;x&quot;:814.6321652033943,&quot;y&quot;:0.0,&quot;category&quot;:1},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EEnum.gif&quot;,&quot;id&quot;:&quot;InputType@https://nasdanika.org/models/ui&quot;,&quot;name&quot;:&quot;InputType&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/InputType/index.html&quot;},&quot;x&quot;:474.5630762701468,&quot;y&quot;:800.0,&quot;category&quot;:1}],&quot;symbolSize&quot;:20,&quot;roam&quot;:true,&quot;layout&quot;:&quot;force&quot;,&quot;links&quot;:[{&quot;source&quot;:1,&quot;target&quot;:0},{&quot;source&quot;:1,&quot;target&quot;:2},{&quot;source&quot;:2,&quot;target&quot;:0},{&quot;source&quot;:2,&quot;target&quot;:1},{&quot;source&quot;:2,&quot;target&quot;:3},{&quot;source&quot;:2,&quot;target&quot;:8},{&quot;source&quot;:3,&quot;target&quot;:0},{&quot;source&quot;:3,&quot;target&quot;:2},{&quot;source&quot;:3,&quot;target&quot;:4},{&quot;source&quot;:3,&quot;target&quot;:5},{&quot;source&quot;:4,&quot;target&quot;:3},{&quot;source&quot;:4,&quot;target&quot;:0},{&quot;source&quot;:5,&quot;target&quot;:3},{&quot;source&quot;:5,&quot;target&quot;:0},{&quot;source&quot;:5,&quot;target&quot;:6},{&quot;source&quot;:6,&quot;target&quot;:0},{&quot;source&quot;:6,&quot;target&quot;:5},{&quot;source&quot;:6,&quot;target&quot;:7}],&quot;categories&quot;:[{&quot;name&quot;:&quot;ecore&quot;},{&quot;name&quot;:&quot;ui&quot;}],&quot;draggable&quot;:true,&quot;label&quot;:{&quot;show&quot;:true,&quot;position&quot;:&quot;right&quot;},&quot;lineStyle&quot;:{&quot;color&quot;:&quot;source&quot;,&quot;curveness&quot;:0},&quot;force&quot;:{&quot;repulsion&quot;:200,&quot;gravity&quot;:0.1,&quot;edgeLength&quot;:200}}]};&#xA;&#x9;&#x9;option.tooltip = {};&#xA;&#x9;&#x9;option.series[0].tooltip = {&#xA;&#x9;&#x9;&#x9;formatter: function(arg) {&#xA;&#x9;&#x9;&#x9;&#x9;return arg.value ? arg.value.description : null;&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;};&#xA;&#x9;&#x9;myChart.setOption(option);&#xA;&#x9;&#x9;myChart.on(&quot;dblclick&quot;, function(params) {&#xA;&#x9;&#x9;&#x9;if (params.value) {&#xA;&#x9;&#x9;&#x9;&#x9;if (params.value.link) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(params.value.link, &quot;_self&quot;);&#xA;&#x9;&#x9;&#x9;&#x9;} else if (params.value.externalLink) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(params.value.externalLink);&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;});&#xA;&#x9;&#x9;window.addEventListener(&quot;resize&quot;, myChart.resize);&#xA;&#x9;});&#xA;&lt;/script>&#xA;"/>
      <decorator xsi:type="org.nasdanika.models.app:Link" uuid="4d7620bb-7f88-48e9-803a-299251fb4307" id="3eaddf12-502f-46eb-b954-5695e5b01eaf" icon="far fa-question-circle" tooltip="A live force-layout graph of package classifiers showing relationships between them">
