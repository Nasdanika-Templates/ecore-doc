      <source xsi:type="org.nasdanika.exec.content:Interpolator" uuid="e919e8d0-09ec-41c4-a1d8-e4cc69bc442a">
        <source xsi:type="org.nasdanika.exec.content:Text" uuid="e70aca11-e0a2-433a-8cb2-275efa10fdeb" content="*&#xA;Represents a UI input element that collects data from the user.&#xA;It is intentionally agnostic of physical rendering &#x2014; the downstream&#xA;engine decides the widget type (text field, dropdown, date picker, etc.)&#xA;based on inputType, choices, and multiplicity attributes."/>
      </source>
    </content>
