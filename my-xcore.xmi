      <children xsi:type="org.nasdanika.models.app:Action" uuid="27e4e546-8518-413a-8aed-255bb736efef" id="9e8e38ce-08b1-4735-9102-4d7b3f33138a" text="Force Graph 3D" location="force-layout-graph-3d.html">
        <content xsi:type="org.nasdanika.exec.content:Text" uuid="487cde2d-ac5c-49db-9bbb-0d4a59746dc5" content="&lt;div id=&quot;force-graph-16&quot; class=&quot;row&quot; style=&quot;height:70vh;width:100%&quot;>&#xA;&lt;/div>&#xA;&lt;script type=&quot;module&quot;>&#xA;&#x9;import { CSS2DRenderer, CSS2DObject } from 'three/addons/renderers/CSS2DRenderer.js';&#xA;&#x9;import SpriteText from &quot;https://cdn.jsdelivr.net/npm/three-spritetext@1.10.0/dist/three-spritetext.mjs&quot;;&#xA;&#xA;&#x9;        new ForceGraph3D(&#xD;&#xA;                document.getElementById('force-graph-16'), &#xD;&#xA;                {&#xD;&#xA;                        extraRenderers: [&#xD;&#xA;                                new CSS2DRenderer()&#xD;&#xA;                        ]&#xD;&#xA;                })&#xD;&#xA;                .graphData({&#xA;          &quot;nodes&quot;: [&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&#xA;              &quot;size&quot;: 4,&#xA;              &quot;name&quot;: &quot;UIFeature&quot;,&#xA;              &quot;id&quot;: &quot;UIFeature@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;../UIFeature/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;https://nasdanika.org/models/ui&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EDataType.gif&quot;,&#xA;              &quot;name&quot;: &quot;EJavaObject&quot;,&#xA;              &quot;id&quot;: &quot;EJavaObject@http://www.eclipse.org/emf/2002/Ecore&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;index.html&quot;}],&#xA;              &quot;group&quot;: &quot;http://www.eclipse.org/emf/2002/Ecore&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EEnum.gif&quot;,&#xA;              &quot;name&quot;: &quot;InputType&quot;,&#xA;              &quot;id&quot;: &quot;InputType@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;../InputType/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;https://nasdanika.org/models/ui&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&#xA;              &quot;size&quot;: 4,&#xA;              &quot;name&quot;: &quot;Choice&quot;,&#xA;              &quot;id&quot;: &quot;Choice@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;../Choice/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;https://nasdanika.org/models/ui&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&#xA;              &quot;size&quot;: 5,&#xA;              &quot;name&quot;: &quot;Input&quot;,&#xA;              &quot;id&quot;: &quot;Input@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;&quot;}],&#xA;              &quot;group&quot;: &quot;https://nasdanika.org/models/ui&quot;&#xA;            }&#xA;          ],&#xA;          &quot;links&quot;: [&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;Input@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;target&quot;: &quot;UIFeature@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;group&quot;: &quot;inheritance&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;name&quot;: &quot;choices&quot;,&#xA;              &quot;source&quot;: &quot;Input@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;target&quot;: &quot;Choice@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;group&quot;: &quot;reference&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            }&#xA;          ]&#xA;        })&#xD;&#xA;                .nodeAutoColorBy('group')&#xD;&#xA;                .nodeVal('size')&#xD;&#xA;                .linkDirectionalArrowLength(2.5)&#xD;&#xA;                .linkDirectionalArrowRelPos(1)&#xD;&#xA;                .linkCurvature('curvature')&#xD;&#xA;                .linkCurveRotation('rotation')&#xD;&#xA;                .linkAutoColorBy('group')&#xD;&#xA;                .onNodeClick((node, event) => {&#xA;       if (node.lastClick) {&#xA;        if (event.timeStamp - node.lastClick &lt; 500) {&#xA;&#x9;&#x9;&#x9;if (Array.isArray(node.value) &amp;&amp; node.value.length > 0) {&#xA;&#x9;&#x9;&#x9;&#x9;if (node.value[0].link) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(node.value[0].link, &quot;_self&quot;);&#xA;&#x9;&#x9;&#x9;&#x9;} else if (node.value[0].externalLink) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(node.value[0].externalLink);&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;delete node.lastClick;&#xA;&#x9;&#x9;} else {&#xA;&#x9;&#x9;&#x9;node.lastClick = event.timeStamp;&#xA;&#x9;&#x9;}&#xA;&#x9;} else {&#xA;&#x9;&#x9;node.lastClick = event.timeStamp;&#xA;&#x9;}&#xA;   })&#xD;&#xA;                .nodeThreeObject(node => {&#xA;        const nodeEl = document.createElement('div');&#xA;        nodeEl.textContent = node.name;&#xA;        nodeEl.style.color = node.color;&#xA;        nodeEl.className = 'node-label';&#xA;        return new CSS2DObject(nodeEl);&#xA;      })&#xD;&#xA;                .nodeThreeObjectExtend(true)&#xD;&#xA;                .linkThreeObject(link => {&#xA;         // extend link with text sprite&#xA;         if (link.name &amp;&amp; !link.curvature) {&#xA;           const sprite = new SpriteText(link.name);&#xA;           sprite.color = 'lightgrey';&#xA;           sprite.textHeight = 1.5;&#xA;           return sprite;&#xA;         }&#xA;       })&#xD;&#xA;                .linkPositionUpdate((sprite, { start, end }) => {&#xA;&#x9;&#x9;if (sprite) {&#xA;          const pos = Object.assign(...['x', 'y', 'z'].map(c => ({&#xA;            [c]: start[c] + (end[c] - start[c]) / 1.3&#xA;          })));&#xA;&#xA;          // Position sprite&#xA;          Object.assign(sprite.position, pos);&#xA;        }&#xA;       })&#xD;&#xA;                .linkThreeObjectExtend(true)&#xD;&#xA;                .onNodeDragEnd(node => {&#xA;          node.fx = node.x;&#xA;          node.fy = node.y;&#xA;          node.fz = node.z;&#xA;        })&#xA;&lt;/script>&#xA;"/>
        <decorator xsi:type="org.nasdanika.models.app:Link" uuid="0f03cd6c-686f-4830-8b3d-ccd7d7f740c3" id="24c235f8-4d77-4a68-b9bc-c22024c3cb80" icon="far fa-question-circle" tooltip="A live force-layout graph of package classifiers showing detailed relationships between them">
