      <source xsi:type="org.nasdanika.exec.content:Interpolator" uuid="76bb3a33-926a-4e9c-84bd-d5b7ab59a0f4">
        <source xsi:type="org.nasdanika.exec.content:Text" uuid="d47ad6f4-3d33-4925-8ba1-7b643a4c80f1" content="*&#xA;A structural grouping element that logically organizes other UI elements.&#xA;It has no data-interaction of its own but provides a container for layout&#xA;and visual grouping (analogous to an HTML fieldset, a Bootstrap row/column,&#xA;or a React fragment with a layout wrapper)."/>
      </source>
    </content>
