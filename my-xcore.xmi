          <source xsi:type="org.nasdanika.exec.content:Interpolator" uuid="c125037f-6d59-42f1-8b1f-6175fd5ed916">
            <source xsi:type="org.nasdanika.exec.content:Text" uuid="2b4b327e-5214-47cc-b5df-456e3e8fa445" content="*&#xA;Controls how the choices list is interpreted by the rendering engine:&#xA;- If true (strict), the user MUST select from the provided choices list&#xA;  (e.g., a dropdown or radio buttons with no free-text option).&#xA;- If false (non-strict), the choices are suggestions or autocomplete hints,&#xA;  but the user may also enter a value not in the list (e.g., a combobox).&#xA;Defaults to false."/>
          </source>
        </content>
