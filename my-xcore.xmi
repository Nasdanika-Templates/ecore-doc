        <content xsi:type="org.nasdanika.exec.content:Text" uuid="09b68ba4-b54e-48ee-b1ca-74114c2d50d8" content="&lt;div id=&quot;graph-container-17&quot; class=&quot;row&quot; style=&quot;height:70vh;width:100%&quot;>&#xA;&lt;/div>&#xA;&lt;script type=&quot;text/javascript&quot;>&#xA;&#x9;$(document).ready(function() {&#xA;&#x9;&#x9;var dom = document.getElementById(&quot;graph-container-17&quot;);&#xA;&#x9;&#x9;var myChart = echarts.init(dom, null, {&#xA;&#x9;&#x9;&#x9;render: &quot;canvas&quot;,&#xA;&#x9;&#x9;&#x9;useDirtyRect: false&#xA;&#x9;&#x9;});&#xA;&#x9;&#x9;var option = {&quot;legend&quot;:{},&quot;series&quot;:[{&quot;type&quot;:&quot;graph&quot;,&quot;emphasis&quot;:{&quot;focus&quot;:&quot;adjacency&quot;},&quot;data&quot;:[{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&quot;id&quot;:&quot;UIFeature@https://nasdanika.org/models/ui&quot;,&quot;name&quot;:&quot;UIFeature&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;../UIFeature/index.html&quot;},&quot;x&quot;:674.6630547907217,&quot;y&quot;:424.30337385896195,&quot;category&quot;:0},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EDataType.gif&quot;,&quot;id&quot;:&quot;EJavaObject@http://www.eclipse.org/emf/2002/Ecore&quot;,&quot;name&quot;:&quot;EJavaObject&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;index.html&quot;},&quot;x&quot;:503.47853641932375,&quot;y&quot;:233.9479363728231,&quot;category&quot;:1},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&quot;id&quot;:&quot;Output@https://nasdanika.org/models/ui&quot;,&quot;name&quot;:&quot;Output&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;&quot;},&quot;x&quot;:424.2181509935259,&quot;y&quot;:477.375796760127,&quot;category&quot;:0}],&quot;symbolSize&quot;:20,&quot;roam&quot;:true,&quot;layout&quot;:&quot;none&quot;,&quot;links&quot;:[{&quot;source&quot;:0,&quot;target&quot;:1},{&quot;source&quot;:0,&quot;target&quot;:2},{&quot;source&quot;:2,&quot;target&quot;:0},{&quot;source&quot;:2,&quot;target&quot;:1}],&quot;categories&quot;:[{&quot;name&quot;:&quot;ui&quot;},{&quot;name&quot;:&quot;ecore&quot;}],&quot;draggable&quot;:true,&quot;label&quot;:{&quot;show&quot;:true,&quot;position&quot;:&quot;right&quot;},&quot;lineStyle&quot;:{&quot;color&quot;:&quot;source&quot;,&quot;curveness&quot;:0}}]};&#xA;&#x9;&#x9;option.tooltip = {};&#xA;&#x9;&#x9;option.series[0].tooltip = {&#xA;&#x9;&#x9;&#x9;formatter: function(arg) {&#xA;&#x9;&#x9;&#x9;&#x9;return arg.value ? arg.value.description : null;&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;};&#xA;&#x9;&#x9;myChart.setOption(option);&#xA;&#x9;&#x9;myChart.on(&quot;dblclick&quot;, function(params) {&#xA;&#x9;&#x9;&#x9;if (params.value) {&#xA;&#x9;&#x9;&#x9;&#x9;if (params.value.link) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(params.value.link, &quot;_self&quot;);&#xA;&#x9;&#x9;&#x9;&#x9;} else if (params.value.externalLink) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(params.value.externalLink);&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;});&#xA;&#x9;&#x9;window.addEventListener(&quot;resize&quot;, myChart.resize);&#xA;&#x9;});&#xA;&lt;/script>&#xA;"/>
