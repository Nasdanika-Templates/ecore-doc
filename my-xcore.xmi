          </attributes>
          <modal uuid="9f642ab0-b78b-48b2-9a4e-e9ff8d9b1e62">
            <body uuid="ba863fcd-da2f-40d7-a91a-bac2989cec9e">
              <content xsi:type="org.nasdanika.exec.content:Text" uuid="77486b93-efe9-4f92-8dce-e49b97b01022" content="Hover mouse over nodes elements to display tooltips.&#xA;Double-click on nodes to navigate go documentation.&#xA;Left click - rotate.&#xA;Mouse wheel - zoom.&#xA;Right click - pan.&#xA;Drag to rearrange.&#xA;"/>
            </body>
          </modal>
        </decorator>
