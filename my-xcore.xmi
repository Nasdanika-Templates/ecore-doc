    <children xsi:type="org.nasdanika.models.app:Action" uuid="c5b6ea76-b519-4439-990d-3b04a691ffc9" id="d861ff82-f233-4f8e-b6a0-34f1ca6c98be" text="Force Graph 3D" location="force-layout-graph-3d-with-dependencies-and-subpackages.html">
      <content xsi:type="org.nasdanika.exec.content:Text" uuid="7cc9beff-1f3a-4d20-ab0d-54d082058a6f" content="&lt;div id=&quot;force-graph33&quot; class=&quot;row&quot; style=&quot;height:70vh;width:100%&quot;>&#xA;&lt;/div>&#xA;&lt;script type=&quot;module&quot;>&#xA;&#x9;import { CSS2DRenderer, CSS2DObject } from 'three/addons/renderers/CSS2DRenderer.js';&#xA;&#x9;import SpriteText from &quot;https://cdn.jsdelivr.net/npm/three-spritetext@1.10.0/dist/three-spritetext.mjs&quot;;&#xA;&#xA;&#x9;        new ForceGraph3D(&#xD;&#xA;                document.getElementById('force-graph33'), &#xD;&#xA;                {&#xD;&#xA;                        extraRenderers: [&#xD;&#xA;                                new CSS2DRenderer()&#xD;&#xA;                        ]&#xD;&#xA;                })&#xD;&#xA;                .graphData({&#xA;          &quot;nodes&quot;: [&#xA;            {&#xA;              &quot;name&quot;: &quot;EJavaObject&quot;,&#xA;              &quot;id&quot;: &quot;EJavaObject@http://www.eclipse.org/emf/2002/Ecore&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;index.html&quot;}],&#xA;              &quot;group&quot;: &quot;ecore&quot;&#xA;            },&#xA;            {&#xA;              &quot;name&quot;: &quot;Choice&quot;,&#xA;              &quot;id&quot;: &quot;Choice@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/Choice/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;ui&quot;&#xA;            },&#xA;            {&#xA;              &quot;name&quot;: &quot;Input&quot;,&#xA;              &quot;id&quot;: &quot;Input@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/Input/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;ui&quot;&#xA;            },&#xA;            {&#xA;              &quot;name&quot;: &quot;UIFeature&quot;,&#xA;              &quot;id&quot;: &quot;UIFeature@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/UIFeature/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;ui&quot;&#xA;            },&#xA;            {&#xA;              &quot;name&quot;: &quot;Output&quot;,&#xA;              &quot;id&quot;: &quot;Output@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/Output/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;ui&quot;&#xA;            },&#xA;            {&#xA;              &quot;name&quot;: &quot;UIElement&quot;,&#xA;              &quot;id&quot;: &quot;UIElement@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/UIElement/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;ui&quot;&#xA;            },&#xA;            {&#xA;              &quot;name&quot;: &quot;UIGroup&quot;,&#xA;              &quot;id&quot;: &quot;UIGroup@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/UIGroup/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;ui&quot;&#xA;            },&#xA;            {&#xA;              &quot;name&quot;: &quot;GroupStyle&quot;,&#xA;              &quot;id&quot;: &quot;GroupStyle@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/GroupStyle/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;ui&quot;&#xA;            },&#xA;            {&#xA;              &quot;name&quot;: &quot;InputType&quot;,&#xA;              &quot;id&quot;: &quot;InputType@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/InputType/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;ui&quot;&#xA;            }&#xA;          ],&#xA;          &quot;links&quot;: [&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;Choice@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;target&quot;: &quot;EJavaObject@http://www.eclipse.org/emf/2002/Ecore&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;Choice@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;target&quot;: &quot;Input@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;Input@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;target&quot;: &quot;EJavaObject@http://www.eclipse.org/emf/2002/Ecore&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;Input@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;target&quot;: &quot;Choice@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;Input@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;target&quot;: &quot;UIFeature@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;Input@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;target&quot;: &quot;InputType@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;UIFeature@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;target&quot;: &quot;EJavaObject@http://www.eclipse.org/emf/2002/Ecore&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;UIFeature@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;target&quot;: &quot;Input@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;UIFeature@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;target&quot;: &quot;Output@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;UIFeature@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;target&quot;: &quot;UIElement@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;Output@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;target&quot;: &quot;UIFeature@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;Output@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;target&quot;: &quot;EJavaObject@http://www.eclipse.org/emf/2002/Ecore&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;UIElement@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;target&quot;: &quot;UIFeature@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;UIElement@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;target&quot;: &quot;EJavaObject@http://www.eclipse.org/emf/2002/Ecore&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;UIElement@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;target&quot;: &quot;UIGroup@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;UIGroup@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;target&quot;: &quot;EJavaObject@http://www.eclipse.org/emf/2002/Ecore&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;UIGroup@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;target&quot;: &quot;UIElement@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;UIGroup@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;target&quot;: &quot;GroupStyle@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            }&#xA;          ]&#xA;        })&#xD;&#xA;                .nodeAutoColorBy('group')&#xD;&#xA;                .nodeVal('size')&#xD;&#xA;                .linkDirectionalArrowLength(2.5)&#xD;&#xA;                .linkDirectionalArrowRelPos(1)&#xD;&#xA;                .linkCurvature('curvature')&#xD;&#xA;                .linkCurveRotation('rotation')&#xD;&#xA;                .onNodeClick((node, event) => {&#xA;       if (node.lastClick) {&#xA;        if (event.timeStamp - node.lastClick &lt; 500) {&#xA;&#x9;&#x9;&#x9;if (Array.isArray(node.value) &amp;&amp; node.value.length > 0) {&#xA;&#x9;&#x9;&#x9;&#x9;if (node.value[0].link) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(node.value[0].link, &quot;_self&quot;);&#xA;&#x9;&#x9;&#x9;&#x9;} else if (node.value[0].externalLink) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(node.value[0].externalLink);&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;delete node.lastClick;&#xA;&#x9;&#x9;} else {&#xA;&#x9;&#x9;&#x9;node.lastClick = event.timeStamp;&#xA;&#x9;&#x9;}&#xA;&#x9;} else {&#xA;&#x9;&#x9;node.lastClick = event.timeStamp;&#xA;&#x9;}&#xA;   })&#xD;&#xA;                .nodeThreeObject(node => {&#xA;        const nodeEl = document.createElement('div');&#xA;        nodeEl.textContent = node.name;&#xA;        nodeEl.style.color = node.color;&#xA;        nodeEl.className = 'node-label';&#xA;        return new CSS2DObject(nodeEl);&#xA;      })&#xD;&#xA;                .nodeThreeObjectExtend(true)&#xD;&#xA;                .onNodeDragEnd(node => {&#xA;          node.fx = node.x;&#xA;          node.fy = node.y;&#xA;          node.fz = node.z;&#xA;        })&#xA;&lt;/script>&#xA;"/>
      <decorator xsi:type="org.nasdanika.models.app:Link" uuid="411ec9f8-3d4d-4b83-97ab-b923ad551d51" id="e085b4bd-bc9f-4c6e-9d8a-d8abc0a610e1" icon="far fa-question-circle" tooltip="A live force-layout graph of package classifiers showing relationships between them">
        <attributes key="style">
          <value xsi:type="org.nasdanika.exec.content:Text" uuid="8caf154b-5848-4ecf-a770-dcf3b1d3a7f7" content="vertical-align:super;font-size:x-small;margin-left:0.2em"/>
        </attributes>
        <modal uuid="089ec1ee-0b5e-43e3-9905-47eb64e114a8">
          <body uuid="6cc8f77f-b532-41c6-81d8-dfcd76b7c2d5">
            <content xsi:type="org.nasdanika.exec.content:Text" uuid="72a989ee-d624-4c91-9386-acc8f69ce742" content="Hover mouse over nodes elements to display tooltips.&#xA;Double-click on nodes to navigate go documentation.&#xA;Left click - rotate.&#xA;Mouse wheel - zoom.&#xA;Right click - pan.&#xA;Drag to rearrange.&#xA;"/>
          </body>
        </modal>
      </decorator>
    </children>
    <children xsi:type="org.nasdanika.models.app:Action" uuid="c8a42947-80a3-410b-8d25-32fe8c9ebb6d" id="3f032737-800d-4c02-a871-ff5d142c4f08" text="Force Graph 3D Detailed" location="force-layout-graph-3d-with-dependencies-and-subpackages-detailed.html">
      <content xsi:type="org.nasdanika.exec.content:Text" uuid="d2b75785-6e01-4019-85c8-30f6e2c4f67a" content="&lt;div id=&quot;force-graph-34&quot; class=&quot;row&quot; style=&quot;height:70vh;width:100%&quot;>&#xA;&lt;/div>&#xA;&lt;script type=&quot;module&quot;>&#xA;&#x9;import { CSS2DRenderer, CSS2DObject } from 'three/addons/renderers/CSS2DRenderer.js';&#xA;&#x9;import SpriteText from &quot;https://cdn.jsdelivr.net/npm/three-spritetext@1.10.0/dist/three-spritetext.mjs&quot;;&#xA;&#xA;&#x9;        new ForceGraph3D(&#xD;&#xA;                document.getElementById('force-graph-34'), &#xD;&#xA;                {&#xD;&#xA;                        extraRenderers: [&#xD;&#xA;                                new CSS2DRenderer()&#xD;&#xA;                        ]&#xD;&#xA;                })&#xD;&#xA;                .graphData({&#xA;          &quot;nodes&quot;: [&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EDataType.gif&quot;,&#xA;              &quot;name&quot;: &quot;EJavaObject&quot;,&#xA;              &quot;id&quot;: &quot;EJavaObject@http://www.eclipse.org/emf/2002/Ecore&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;index.html&quot;}],&#xA;              &quot;group&quot;: &quot;http://www.eclipse.org/emf/2002/Ecore&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&#xA;              &quot;size&quot;: 4,&#xA;              &quot;name&quot;: &quot;Choice&quot;,&#xA;              &quot;id&quot;: &quot;Choice@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/Choice/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;https://nasdanika.org/models/ui&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&#xA;              &quot;size&quot;: 5,&#xA;              &quot;name&quot;: &quot;Input&quot;,&#xA;              &quot;id&quot;: &quot;Input@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/Input/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;https://nasdanika.org/models/ui&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&#xA;              &quot;size&quot;: 4,&#xA;              &quot;name&quot;: &quot;UIFeature&quot;,&#xA;              &quot;id&quot;: &quot;UIFeature@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/UIFeature/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;https://nasdanika.org/models/ui&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&#xA;              &quot;size&quot;: 3,&#xA;              &quot;name&quot;: &quot;Output&quot;,&#xA;              &quot;id&quot;: &quot;Output@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/Output/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;https://nasdanika.org/models/ui&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&#xA;              &quot;size&quot;: 4,&#xA;              &quot;name&quot;: &quot;UIElement&quot;,&#xA;              &quot;id&quot;: &quot;UIElement@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/UIElement/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;https://nasdanika.org/models/ui&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&#xA;              &quot;size&quot;: 4,&#xA;              &quot;name&quot;: &quot;UIGroup&quot;,&#xA;              &quot;id&quot;: &quot;UIGroup@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/UIGroup/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;https://nasdanika.org/models/ui&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EEnum.gif&quot;,&#xA;              &quot;name&quot;: &quot;GroupStyle&quot;,&#xA;              &quot;id&quot;: &quot;GroupStyle@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/GroupStyle/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;https://nasdanika.org/models/ui&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EEnum.gif&quot;,&#xA;              &quot;name&quot;: &quot;InputType&quot;,&#xA;              &quot;id&quot;: &quot;InputType@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/InputType/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;https://nasdanika.org/models/ui&quot;&#xA;            }&#xA;          ],&#xA;          &quot;links&quot;: [&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;name&quot;: &quot;choices&quot;,&#xA;              &quot;source&quot;: &quot;Input@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;target&quot;: &quot;Choice@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;group&quot;: &quot;reference&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;Input@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;target&quot;: &quot;UIFeature@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;group&quot;: &quot;inheritance&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;Output@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;target&quot;: &quot;UIFeature@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;group&quot;: &quot;inheritance&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;UIFeature@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;target&quot;: &quot;UIElement@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;group&quot;: &quot;inheritance&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;UIGroup@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;target&quot;: &quot;UIElement@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;group&quot;: &quot;inheritance&quot;,&#xA;              &quot;curvature&quot;: 0.2&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 3.141592653589793,&#xA;              &quot;name&quot;: &quot;children&quot;,&#xA;              &quot;source&quot;: &quot;UIGroup@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;target&quot;: &quot;UIElement@https://nasdanika.org/models/ui&quot;,&#xA;              &quot;group&quot;: &quot;reference&quot;,&#xA;              &quot;curvature&quot;: 0.2&#xA;            }&#xA;          ]&#xA;        })&#xD;&#xA;                .nodeAutoColorBy('group')&#xD;&#xA;                .nodeVal('size')&#xD;&#xA;                .linkDirectionalArrowLength(2.5)&#xD;&#xA;                .linkDirectionalArrowRelPos(1)&#xD;&#xA;                .linkCurvature('curvature')&#xD;&#xA;                .linkCurveRotation('rotation')&#xD;&#xA;                .linkAutoColorBy('group')&#xD;&#xA;                .onNodeClick((node, event) => {&#xA;       if (node.lastClick) {&#xA;        if (event.timeStamp - node.lastClick &lt; 500) {&#xA;&#x9;&#x9;&#x9;if (Array.isArray(node.value) &amp;&amp; node.value.length > 0) {&#xA;&#x9;&#x9;&#x9;&#x9;if (node.value[0].link) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(node.value[0].link, &quot;_self&quot;);&#xA;&#x9;&#x9;&#x9;&#x9;} else if (node.value[0].externalLink) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(node.value[0].externalLink);&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;delete node.lastClick;&#xA;&#x9;&#x9;} else {&#xA;&#x9;&#x9;&#x9;node.lastClick = event.timeStamp;&#xA;&#x9;&#x9;}&#xA;&#x9;} else {&#xA;&#x9;&#x9;node.lastClick = event.timeStamp;&#xA;&#x9;}&#xA;   })&#xD;&#xA;                .nodeThreeObject(node => {&#xA;        const nodeEl = document.createElement('div');&#xA;        nodeEl.textContent = node.name;&#xA;        nodeEl.style.color = node.color;&#xA;        nodeEl.className = 'node-label';&#xA;        return new CSS2DObject(nodeEl);&#xA;      })&#xD;&#xA;                .nodeThreeObjectExtend(true)&#xD;&#xA;                .linkThreeObject(link => {&#xA;         // extend link with text sprite&#xA;         if (link.name &amp;&amp; !link.curvature) {&#xA;           const sprite = new SpriteText(link.name);&#xA;           sprite.color = 'lightgrey';&#xA;           sprite.textHeight = 1.5;&#xA;           return sprite;&#xA;         }&#xA;       })&#xD;&#xA;                .linkPositionUpdate((sprite, { start, end }) => {&#xA;&#x9;&#x9;if (sprite) {&#xA;          const pos = Object.assign(...['x', 'y', 'z'].map(c => ({&#xA;            [c]: start[c] + (end[c] - start[c]) / 1.3&#xA;          })));&#xA;&#xA;          // Position sprite&#xA;          Object.assign(sprite.position, pos);&#xA;        }&#xA;       })&#xD;&#xA;                .linkThreeObjectExtend(true)&#xD;&#xA;                .onNodeDragEnd(node => {&#xA;          node.fx = node.x;&#xA;          node.fy = node.y;&#xA;          node.fz = node.z;&#xA;        })&#xA;&lt;/script>&#xA;"/>
      <decorator xsi:type="org.nasdanika.models.app:Link" uuid="da267cc9-1602-47cb-a54c-d40ee2c922fa" id="57ef06d7-0a27-4997-82e9-383a983b7278" icon="far fa-question-circle" tooltip="A live force-layout graph of package classifiers showing detailed relationships between them">
        <attributes key="style">
          <value xsi:type="org.nasdanika.exec.content:Text" uuid="55aade47-464b-4058-aa0a-11126bb78923" content="vertical-align:super;font-size:x-small;margin-left:0.2em"/>
        </attributes>
        <modal uuid="8fa8c0c3-41ca-4655-92a0-0ae52ad42505">
          <body uuid="04947ba9-8473-4ebd-87ac-ea1c1cf538d1">
            <content xsi:type="org.nasdanika.exec.content:Text" uuid="ecee9e9e-2b14-42ca-9bda-f196ad73bca3" content="Hover mouse over nodes elements to display tooltips.&#xA;Double-click on nodes to navigate go documentation.&#xA;Left click - rotate.&#xA;Mouse wheel - zoom.&#xA;Right click - pan.&#xA;Drag to rearrange.&#xA;"/>
          </body>
        </modal>
      </decorator>
    </children>
    <decorator uuid="6c406b74-9791-4e40-881d-cf0630f928b6" id="581b825c-f2a8-40de-a346-ad0bb9aa53fa" icon="far fa-question-circle" tooltip="Graphs of package classifiers showing relationships between them">
      <attributes key="style">
        <value xsi:type="org.nasdanika.exec.content:Text" uuid="dc3546f6-02ce-45ae-99f7-9dfc53af7518" content="vertical-align:super;font-size:x-small;margin-left:0.2em"/>
      </attributes>
    </decorator>
  </navigation>
</org.nasdanika.models.app:Action>
