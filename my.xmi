      <children xsi:type="org.nasdanika.models.app:Action" uuid="f2de5bf7-b5de-45bc-9769-234e2a483498" id="6c12a59d-8e32-40da-9bc8-ea8890dbb703" text="Force Graph" location="force-layout-graph.html">
        <content xsi:type="org.nasdanika.exec.content:Text" uuid="067af703-2768-402f-b771-30914ea32d11" content="&lt;div id=&quot;graph-container-3&quot; class=&quot;row&quot; style=&quot;height:70vh;width:100%&quot;>&#xA;&lt;/div>&#xA;&lt;script type=&quot;text/javascript&quot;>&#xA;&#x9;$(document).ready(function() {&#xA;&#x9;&#x9;var dom = document.getElementById(&quot;graph-container-3&quot;);&#xA;&#x9;&#x9;var myChart = echarts.init(dom, null, {&#xA;&#x9;&#x9;&#x9;render: &quot;canvas&quot;,&#xA;&#x9;&#x9;&#x9;useDirtyRect: false&#xA;&#x9;&#x9;});&#xA;&#x9;&#x9;var option = {&quot;legend&quot;:{},&quot;series&quot;:[{&quot;type&quot;:&quot;graph&quot;,&quot;emphasis&quot;:{&quot;focus&quot;:&quot;adjacency&quot;},&quot;data&quot;:[{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EDataType.gif&quot;,&quot;id&quot;:&quot;EString@http://www.eclipse.org/emf/2002/Ecore&quot;,&quot;name&quot;:&quot;EString&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;index.html&quot;},&quot;x&quot;:627.2594265186889,&quot;y&quot;:545.3503787114955,&quot;category&quot;:0},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&quot;id&quot;:&quot;MyClass@ecore://myontology.nasdanika.org&quot;,&quot;name&quot;:&quot;MyClass&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;&quot;},&quot;x&quot;:324.605425247786,&quot;y&quot;:447.6312057431914,&quot;category&quot;:1}],&quot;symbolSize&quot;:20,&quot;roam&quot;:true,&quot;layout&quot;:&quot;force&quot;,&quot;links&quot;:[{&quot;source&quot;:1,&quot;target&quot;:0}],&quot;categories&quot;:[{&quot;name&quot;:&quot;ecore&quot;},{&quot;name&quot;:&quot;mypackage&quot;}],&quot;draggable&quot;:true,&quot;label&quot;:{&quot;show&quot;:true,&quot;position&quot;:&quot;right&quot;},&quot;lineStyle&quot;:{&quot;color&quot;:&quot;source&quot;,&quot;curveness&quot;:0},&quot;force&quot;:{&quot;repulsion&quot;:200,&quot;gravity&quot;:0.1,&quot;edgeLength&quot;:200}}]};&#xA;&#x9;&#x9;option.tooltip = {};&#xA;&#x9;&#x9;option.series[0].tooltip = {&#xA;&#x9;&#x9;&#x9;formatter: function(arg) {&#xA;&#x9;&#x9;&#x9;&#x9;return arg.value ? arg.value.description : null;&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;};&#xA;&#x9;&#x9;myChart.setOption(option);&#xA;&#x9;&#x9;myChart.on(&quot;dblclick&quot;, function(params) {&#xA;&#x9;&#x9;&#x9;if (params.value) {&#xA;&#x9;&#x9;&#x9;&#x9;if (params.value.link) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(params.value.link, &quot;_self&quot;);&#xA;&#x9;&#x9;&#x9;&#x9;} else if (params.value.externalLink) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(params.value.externalLink);&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;});&#xA;&#x9;&#x9;window.addEventListener(&quot;resize&quot;, myChart.resize);&#xA;&#x9;});&#xA;&lt;/script>&#xA;"/>
        <decorator xsi:type="org.nasdanika.models.app:Link" uuid="3faf23aa-8102-4a1d-84a1-ead4bb1c05a6" id="d4486e0d-ce8c-4155-96d5-eaf51ef66a12" icon="far fa-question-circle" tooltip="A live force-layout graph of this classifier and related classifiers showing relationships between them">
          <attributes key="style">
            <value xsi:type="org.nasdanika.exec.content:Text" uuid="82a1964f-0ce2-489d-9bbb-23beec8620df" content="vertical-align:super;font-size:x-small;margin-left:0.2em"/>
          </attributes>
          <modal uuid="1282ecf6-ec8a-447c-afe0-617e82ca1db4">
            <body uuid="b7ce0cb6-21dd-486b-a306-188aeb924802">
              <content xsi:type="org.nasdanika.exec.content:Text" uuid="1776ce15-de7e-4d5f-8d30-72d48360cab8" content="Hover mouse over nodes elements to display tooltips.&#xA;Double-click on nodes to navigate go documentation.&#xA;Drag to rearrange, nodes will not stay in place once released.&#xA;"/>
            </body>
          </modal>
        </decorator>
      </children>
      <children xsi:type="org.nasdanika.models.app:Action" uuid="0426ccc5-ed4d-4c76-a3d3-7972fdb45eeb" id="fed7c532-a2c1-49ac-ac08-a757aac44752" text="Force Graph 3D" location="force-layout-graph-3d.html">
        <content xsi:type="org.nasdanika.exec.content:Text" uuid="6125093c-d769-440c-92ae-16402d4536c6" content="&lt;div id=&quot;force-graph-4&quot; class=&quot;row&quot; style=&quot;height:70vh;width:100%&quot;>&#xA;&lt;/div>&#xA;&lt;script type=&quot;module&quot;>&#xA;&#x9;import { CSS2DRenderer, CSS2DObject } from 'three/addons/renderers/CSS2DRenderer.js';&#xA;&#x9;import SpriteText from &quot;https://cdn.jsdelivr.net/npm/three-spritetext@1.10.0/dist/three-spritetext.mjs&quot;;&#xA;&#xA;&#x9;        new ForceGraph3D(&#xD;&#xA;                document.getElementById('force-graph-4'), &#xD;&#xA;                {&#xD;&#xA;                        extraRenderers: [&#xD;&#xA;                                new CSS2DRenderer()&#xD;&#xA;                        ]&#xD;&#xA;                })&#xD;&#xA;                .graphData({&quot;nodes&quot;: [&#xA;          {&#xA;            &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EDataType.gif&quot;,&#xA;            &quot;name&quot;: &quot;EString&quot;,&#xA;            &quot;id&quot;: &quot;EString@http://www.eclipse.org/emf/2002/Ecore&quot;,&#xA;            &quot;value&quot;: [{&quot;externalLink&quot;: &quot;index.html&quot;}],&#xA;            &quot;group&quot;: &quot;http://www.eclipse.org/emf/2002/Ecore&quot;&#xA;          },&#xA;          {&#xA;            &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&#xA;            &quot;size&quot;: 3,&#xA;            &quot;name&quot;: &quot;MyClass&quot;,&#xA;            &quot;id&quot;: &quot;MyClass@ecore://myontology.nasdanika.org&quot;,&#xA;            &quot;value&quot;: [{&quot;externalLink&quot;: &quot;&quot;}],&#xA;            &quot;group&quot;: &quot;ecore://myontology.nasdanika.org&quot;&#xA;          }&#xA;        ]})&#xD;&#xA;                .nodeAutoColorBy('group')&#xD;&#xA;                .nodeVal('size')&#xD;&#xA;                .linkDirectionalArrowLength(2.5)&#xD;&#xA;                .linkDirectionalArrowRelPos(1)&#xD;&#xA;                .linkCurvature('curvature')&#xD;&#xA;                .linkCurveRotation('rotation')&#xD;&#xA;                .linkAutoColorBy('group')&#xD;&#xA;                .onNodeClick((node, event) => {&#xA;       if (node.lastClick) {&#xA;        if (event.timeStamp - node.lastClick &lt; 500) {&#xA;&#x9;&#x9;&#x9;if (Array.isArray(node.value) &amp;&amp; node.value.length > 0) {&#xA;&#x9;&#x9;&#x9;&#x9;if (node.value[0].link) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(node.value[0].link, &quot;_self&quot;);&#xA;&#x9;&#x9;&#x9;&#x9;} else if (node.value[0].externalLink) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(node.value[0].externalLink);&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;delete node.lastClick;&#xA;&#x9;&#x9;} else {&#xA;&#x9;&#x9;&#x9;node.lastClick = event.timeStamp;&#xA;&#x9;&#x9;}&#xA;&#x9;} else {&#xA;&#x9;&#x9;node.lastClick = event.timeStamp;&#xA;&#x9;}&#xA;   })&#xD;&#xA;                .nodeThreeObject(node => {&#xA;        const nodeEl = document.createElement('div');&#xA;        nodeEl.textContent = node.name;&#xA;        nodeEl.style.color = node.color;&#xA;        nodeEl.className = 'node-label';&#xA;        return new CSS2DObject(nodeEl);&#xA;      })&#xD;&#xA;                .nodeThreeObjectExtend(true)&#xD;&#xA;                .linkThreeObject(link => {&#xA;         // extend link with text sprite&#xA;         if (link.name &amp;&amp; !link.curvature) {&#xA;           const sprite = new SpriteText(link.name);&#xA;           sprite.color = 'lightgrey';&#xA;           sprite.textHeight = 1.5;&#xA;           return sprite;&#xA;         }&#xA;       })&#xD;&#xA;                .linkPositionUpdate((sprite, { start, end }) => {&#xA;&#x9;&#x9;if (sprite) {&#xA;          const pos = Object.assign(...['x', 'y', 'z'].map(c => ({&#xA;            [c]: start[c] + (end[c] - start[c]) / 1.3&#xA;          })));&#xA;&#xA;          // Position sprite&#xA;          Object.assign(sprite.position, pos);&#xA;        }&#xA;       })&#xD;&#xA;                .linkThreeObjectExtend(true)&#xD;&#xA;                .onNodeDragEnd(node => {&#xA;          node.fx = node.x;&#xA;          node.fy = node.y;&#xA;          node.fz = node.z;&#xA;        })&#xA;&lt;/script>&#xA;"/>
        <decorator xsi:type="org.nasdanika.models.app:Link" uuid="ea1dcb0e-b897-442d-820b-53809d2f1907" id="c5512f15-49eb-46b7-b764-c88434d03984" icon="far fa-question-circle" tooltip="A live force-layout graph of package classifiers showing detailed relationships between them">
          <attributes key="style">
            <value xsi:type="org.nasdanika.exec.content:Text" uuid="5c1bd4d8-a1ed-46bc-9719-80806b9e95b3" content="vertical-align:super;font-size:x-small;margin-left:0.2em"/>
          </attributes>
          <modal uuid="38aabbc8-da1a-482a-9856-b77cd53b3968">
            <body uuid="51e13e46-78ad-48bb-ac20-54b7248c88d1">
              <content xsi:type="org.nasdanika.exec.content:Text" uuid="9dd82abb-5302-4f51-9e1d-9dc5a6b303a1" content="Hover mouse over nodes elements to display tooltips.&#xA;Double-click on nodes to navigate go documentation.&#xA;Left click - rotate.&#xA;Mouse wheel - zoom.&#xA;Right click - pan.&#xA;Drag to rearrange.&#xA;"/>
            </body>
          </modal>
        </decorator>
      </children>
