    <children xsi:type="org.nasdanika.models.app:Action" uuid="1560c316-e946-4562-b6a9-d1bced8f9667" id="8c3f0e70-e422-4799-8fe5-dbee68f084be" text="Force Graph 3D" location="force-layout-graph-3d-with-dependencies-and-subpackages.html">
      <content xsi:type="org.nasdanika.exec.content:Text" uuid="11211136-8444-4d65-8c07-0911d6631bce" content="&lt;div id=&quot;force-graph13&quot; class=&quot;row&quot; style=&quot;height:70vh;width:100%&quot;>&#xA;&lt;/div>&#xA;&lt;script type=&quot;module&quot;>&#xA;&#x9;import { CSS2DRenderer, CSS2DObject } from 'three/addons/renderers/CSS2DRenderer.js';&#xA;&#x9;import SpriteText from &quot;https://cdn.jsdelivr.net/npm/three-spritetext@1.10.0/dist/three-spritetext.mjs&quot;;&#xA;&#xA;&#x9;        new ForceGraph3D(&#xD;&#xA;                document.getElementById('force-graph13'), &#xD;&#xA;                {&#xD;&#xA;                        extraRenderers: [&#xD;&#xA;                                new CSS2DRenderer()&#xD;&#xA;                        ]&#xD;&#xA;                })&#xD;&#xA;                .graphData({&#xA;          &quot;nodes&quot;: [&#xA;            {&#xA;              &quot;name&quot;: &quot;EString&quot;,&#xA;              &quot;id&quot;: &quot;EString@http://www.eclipse.org/emf/2002/Ecore&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;index.html&quot;}],&#xA;              &quot;group&quot;: &quot;ecore&quot;&#xA;            },&#xA;            {&#xA;              &quot;name&quot;: &quot;MyClass&quot;,&#xA;              &quot;id&quot;: &quot;MyClass@ecore://myontology.nasdanika.org&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/MyClass/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;mypackage&quot;&#xA;            }&#xA;          ],&#xA;          &quot;links&quot;: [{&#xA;            &quot;rotation&quot;: 0,&#xA;            &quot;source&quot;: &quot;MyClass@ecore://myontology.nasdanika.org&quot;,&#xA;            &quot;target&quot;: &quot;EString@http://www.eclipse.org/emf/2002/Ecore&quot;,&#xA;            &quot;curvature&quot;: 0&#xA;          }]&#xA;        })&#xD;&#xA;                .nodeAutoColorBy('group')&#xD;&#xA;                .nodeVal('size')&#xD;&#xA;                .linkDirectionalArrowLength(2.5)&#xD;&#xA;                .linkDirectionalArrowRelPos(1)&#xD;&#xA;                .linkCurvature('curvature')&#xD;&#xA;                .linkCurveRotation('rotation')&#xD;&#xA;                .onNodeClick((node, event) => {&#xA;       if (node.lastClick) {&#xA;        if (event.timeStamp - node.lastClick &lt; 500) {&#xA;&#x9;&#x9;&#x9;if (Array.isArray(node.value) &amp;&amp; node.value.length > 0) {&#xA;&#x9;&#x9;&#x9;&#x9;if (node.value[0].link) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(node.value[0].link, &quot;_self&quot;);&#xA;&#x9;&#x9;&#x9;&#x9;} else if (node.value[0].externalLink) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(node.value[0].externalLink);&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;delete node.lastClick;&#xA;&#x9;&#x9;} else {&#xA;&#x9;&#x9;&#x9;node.lastClick = event.timeStamp;&#xA;&#x9;&#x9;}&#xA;&#x9;} else {&#xA;&#x9;&#x9;node.lastClick = event.timeStamp;&#xA;&#x9;}&#xA;   })&#xD;&#xA;                .nodeThreeObject(node => {&#xA;        const nodeEl = document.createElement('div');&#xA;        nodeEl.textContent = node.name;&#xA;        nodeEl.style.color = node.color;&#xA;        nodeEl.className = 'node-label';&#xA;        return new CSS2DObject(nodeEl);&#xA;      })&#xD;&#xA;                .nodeThreeObjectExtend(true)&#xD;&#xA;                .onNodeDragEnd(node => {&#xA;          node.fx = node.x;&#xA;          node.fy = node.y;&#xA;          node.fz = node.z;&#xA;        })&#xA;&lt;/script>&#xA;"/>
      <decorator xsi:type="org.nasdanika.models.app:Link" uuid="52aa0e57-957b-4fd1-8106-792b7736d68c" id="915538d1-333d-48f5-a1de-ba472ad0e0b1" icon="far fa-question-circle" tooltip="A live force-layout graph of package classifiers showing relationships between them">
        <attributes key="style">
          <value xsi:type="org.nasdanika.exec.content:Text" uuid="33346511-d35a-4e03-95de-39e48a416db0" content="vertical-align:super;font-size:x-small;margin-left:0.2em"/>
        </attributes>
        <modal uuid="6fe9d83b-b41d-489c-a946-7da099926f33">
          <body uuid="39077875-3b88-4059-9ee6-e81a058f66bd">
            <content xsi:type="org.nasdanika.exec.content:Text" uuid="ba59f9a9-865d-4b02-998e-37b0b753f7f9" content="Hover mouse over nodes elements to display tooltips.&#xA;Double-click on nodes to navigate go documentation.&#xA;Left click - rotate.&#xA;Mouse wheel - zoom.&#xA;Right click - pan.&#xA;Drag to rearrange.&#xA;"/>
          </body>
        </modal>
      </decorator>
    </children>
    <children xsi:type="org.nasdanika.models.app:Action" uuid="c6d6ab4d-cc85-4e3c-ab8e-1b16362acd73" id="a2744875-cede-4824-a25b-a662c358b856" text="Force Graph 3D Detailed" location="force-layout-graph-3d-with-dependencies-and-subpackages-detailed.html">
      <content xsi:type="org.nasdanika.exec.content:Text" uuid="304885eb-6dc7-48e8-96ea-e5c257d11063" content="&lt;div id=&quot;force-graph-14&quot; class=&quot;row&quot; style=&quot;height:70vh;width:100%&quot;>&#xA;&lt;/div>&#xA;&lt;script type=&quot;module&quot;>&#xA;&#x9;import { CSS2DRenderer, CSS2DObject } from 'three/addons/renderers/CSS2DRenderer.js';&#xA;&#x9;import SpriteText from &quot;https://cdn.jsdelivr.net/npm/three-spritetext@1.10.0/dist/three-spritetext.mjs&quot;;&#xA;&#xA;&#x9;        new ForceGraph3D(&#xD;&#xA;                document.getElementById('force-graph-14'), &#xD;&#xA;                {&#xD;&#xA;                        extraRenderers: [&#xD;&#xA;                                new CSS2DRenderer()&#xD;&#xA;                        ]&#xD;&#xA;                })&#xD;&#xA;                .graphData({&quot;nodes&quot;: [&#xA;          {&#xA;            &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EDataType.gif&quot;,&#xA;            &quot;name&quot;: &quot;EString&quot;,&#xA;            &quot;id&quot;: &quot;EString@http://www.eclipse.org/emf/2002/Ecore&quot;,&#xA;            &quot;value&quot;: [{&quot;externalLink&quot;: &quot;index.html&quot;}],&#xA;            &quot;group&quot;: &quot;http://www.eclipse.org/emf/2002/Ecore&quot;&#xA;          },&#xA;          {&#xA;            &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&#xA;            &quot;size&quot;: 3,&#xA;            &quot;name&quot;: &quot;MyClass&quot;,&#xA;            &quot;id&quot;: &quot;MyClass@ecore://myontology.nasdanika.org&quot;,&#xA;            &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/MyClass/index.html&quot;}],&#xA;            &quot;group&quot;: &quot;ecore://myontology.nasdanika.org&quot;&#xA;          }&#xA;        ]})&#xD;&#xA;                .nodeAutoColorBy('group')&#xD;&#xA;                .nodeVal('size')&#xD;&#xA;                .linkDirectionalArrowLength(2.5)&#xD;&#xA;                .linkDirectionalArrowRelPos(1)&#xD;&#xA;                .linkCurvature('curvature')&#xD;&#xA;                .linkCurveRotation('rotation')&#xD;&#xA;                .linkAutoColorBy('group')&#xD;&#xA;                .onNodeClick((node, event) => {&#xA;       if (node.lastClick) {&#xA;        if (event.timeStamp - node.lastClick &lt; 500) {&#xA;&#x9;&#x9;&#x9;if (Array.isArray(node.value) &amp;&amp; node.value.length > 0) {&#xA;&#x9;&#x9;&#x9;&#x9;if (node.value[0].link) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(node.value[0].link, &quot;_self&quot;);&#xA;&#x9;&#x9;&#x9;&#x9;} else if (node.value[0].externalLink) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(node.value[0].externalLink);&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;delete node.lastClick;&#xA;&#x9;&#x9;} else {&#xA;&#x9;&#x9;&#x9;node.lastClick = event.timeStamp;&#xA;&#x9;&#x9;}&#xA;&#x9;} else {&#xA;&#x9;&#x9;node.lastClick = event.timeStamp;&#xA;&#x9;}&#xA;   })&#xD;&#xA;                .nodeThreeObject(node => {&#xA;        const nodeEl = document.createElement('div');&#xA;        nodeEl.textContent = node.name;&#xA;        nodeEl.style.color = node.color;&#xA;        nodeEl.className = 'node-label';&#xA;        return new CSS2DObject(nodeEl);&#xA;      })&#xD;&#xA;                .nodeThreeObjectExtend(true)&#xD;&#xA;                .linkThreeObject(link => {&#xA;         // extend link with text sprite&#xA;         if (link.name &amp;&amp; !link.curvature) {&#xA;           const sprite = new SpriteText(link.name);&#xA;           sprite.color = 'lightgrey';&#xA;           sprite.textHeight = 1.5;&#xA;           return sprite;&#xA;         }&#xA;       })&#xD;&#xA;                .linkPositionUpdate((sprite, { start, end }) => {&#xA;&#x9;&#x9;if (sprite) {&#xA;          const pos = Object.assign(...['x', 'y', 'z'].map(c => ({&#xA;            [c]: start[c] + (end[c] - start[c]) / 1.3&#xA;          })));&#xA;&#xA;          // Position sprite&#xA;          Object.assign(sprite.position, pos);&#xA;        }&#xA;       })&#xD;&#xA;                .linkThreeObjectExtend(true)&#xD;&#xA;                .onNodeDragEnd(node => {&#xA;          node.fx = node.x;&#xA;          node.fy = node.y;&#xA;          node.fz = node.z;&#xA;        })&#xA;&lt;/script>&#xA;"/>
      <decorator xsi:type="org.nasdanika.models.app:Link" uuid="8155c6fd-8b49-4734-89b3-b3dbd05d2653" id="e50f28c4-7ad9-410e-9e41-af6a73c05889" icon="far fa-question-circle" tooltip="A live force-layout graph of package classifiers showing detailed relationships between them">
