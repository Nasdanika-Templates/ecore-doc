      <children xsi:type="org.nasdanika.models.app:Action" uuid="079796a8-7e89-4ecc-9065-16a96ff294a1" id="84bbdeeb-63ba-40d8-aaec-a5f2029e526c" text="Force Graph" location="force-layout-graph.html">
        <content xsi:type="org.nasdanika.exec.content:Text" uuid="75018c80-df24-40db-ab81-14d6210413b1" content="&lt;div id=&quot;graph-container-3&quot; class=&quot;row&quot; style=&quot;height:70vh;width:100%&quot;>&#xA;&lt;/div>&#xA;&lt;script type=&quot;text/javascript&quot;>&#xA;&#x9;$(document).ready(function() {&#xA;&#x9;&#x9;var dom = document.getElementById(&quot;graph-container-3&quot;);&#xA;&#x9;&#x9;var myChart = echarts.init(dom, null, {&#xA;&#x9;&#x9;&#x9;render: &quot;canvas&quot;,&#xA;&#x9;&#x9;&#x9;useDirtyRect: false&#xA;&#x9;&#x9;});&#xA;&#x9;&#x9;var option = {&quot;legend&quot;:{},&quot;series&quot;:[{&quot;type&quot;:&quot;graph&quot;,&quot;emphasis&quot;:{&quot;focus&quot;:&quot;adjacency&quot;},&quot;data&quot;:[{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EDataType.gif&quot;,&quot;id&quot;:&quot;EString@http://www.eclipse.org/emf/2002/Ecore&quot;,&quot;name&quot;:&quot;EString&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;index.html&quot;},&quot;x&quot;:124.82047433561416,&quot;y&quot;:450.8308148093997,&quot;category&quot;:0},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&quot;id&quot;:&quot;MyClass@ecore://myontology.nasdanika.org&quot;,&quot;name&quot;:&quot;MyClass&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;&quot;},&quot;x&quot;:416.80947392133584,&quot;y&quot;:327.89348975157964,&quot;category&quot;:1}],&quot;symbolSize&quot;:20,&quot;roam&quot;:true,&quot;layout&quot;:&quot;force&quot;,&quot;links&quot;:[{&quot;source&quot;:1,&quot;target&quot;:0}],&quot;categories&quot;:[{&quot;name&quot;:&quot;ecore&quot;},{&quot;name&quot;:&quot;mypackage&quot;}],&quot;draggable&quot;:true,&quot;label&quot;:{&quot;show&quot;:true,&quot;position&quot;:&quot;right&quot;},&quot;lineStyle&quot;:{&quot;color&quot;:&quot;source&quot;,&quot;curveness&quot;:0},&quot;force&quot;:{&quot;repulsion&quot;:200,&quot;gravity&quot;:0.1,&quot;edgeLength&quot;:200}}]};&#xA;&#x9;&#x9;option.tooltip = {};&#xA;&#x9;&#x9;option.series[0].tooltip = {&#xA;&#x9;&#x9;&#x9;formatter: function(arg) {&#xA;&#x9;&#x9;&#x9;&#x9;return arg.value ? arg.value.description : null;&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;};&#xA;&#x9;&#x9;myChart.setOption(option);&#xA;&#x9;&#x9;myChart.on(&quot;dblclick&quot;, function(params) {&#xA;&#x9;&#x9;&#x9;if (params.value) {&#xA;&#x9;&#x9;&#x9;&#x9;if (params.value.link) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(params.value.link, &quot;_self&quot;);&#xA;&#x9;&#x9;&#x9;&#x9;} else if (params.value.externalLink) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(params.value.externalLink);&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;});&#xA;&#x9;&#x9;window.addEventListener(&quot;resize&quot;, myChart.resize);&#xA;&#x9;});&#xA;&lt;/script>&#xA;"/>
        <decorator xsi:type="org.nasdanika.models.app:Link" uuid="b2aece2b-d83e-41e0-b372-bddeea46a335" id="f18a53aa-07cf-43b4-b9d0-ffec1bf49c97" icon="far fa-question-circle" tooltip="A live force-layout graph of this classifier and related classifiers showing relationships between them">
          <attributes key="style">
            <value xsi:type="org.nasdanika.exec.content:Text" uuid="2e710520-9904-4b2d-bd19-ec9984806c78" content="vertical-align:super;font-size:x-small;margin-left:0.2em"/>
          </attributes>
          <modal uuid="2eeb8b2e-64a1-4779-ac5f-48b97aba5939">
            <body uuid="896d1628-aeea-407e-9b48-1db7486d6e0b">
              <content xsi:type="org.nasdanika.exec.content:Text" uuid="1f90fadd-209b-4dd9-bf0b-61416af3b523" content="Hover mouse over nodes elements to display tooltips.&#xA;Double-click on nodes to navigate go documentation.&#xA;Drag to rearrange, nodes will not stay in place once released.&#xA;"/>
            </body>
          </modal>
        </decorator>
      </children>
      <children xsi:type="org.nasdanika.models.app:Action" uuid="70598121-a1c9-48f2-a35d-f11dbf303fba" id="b5e2a37e-d258-4627-8cf6-96d601196a28" text="Force Graph 3D" location="force-layout-graph-3d.html">
        <content xsi:type="org.nasdanika.exec.content:Text" uuid="6e630f4b-0650-404b-bbc0-dc90ecab4bd6" content="&lt;div id=&quot;force-graph-4&quot; class=&quot;row&quot; style=&quot;height:70vh;width:100%&quot;>&#xA;&lt;/div>&#xA;&lt;script type=&quot;module&quot;>&#xA;&#x9;import { CSS2DRenderer, CSS2DObject } from 'three/addons/renderers/CSS2DRenderer.js';&#xA;&#x9;import SpriteText from &quot;https://cdn.jsdelivr.net/npm/three-spritetext@1.10.0/dist/three-spritetext.mjs&quot;;&#xA;&#xA;&#x9;        new ForceGraph3D(&#xD;&#xA;                document.getElementById('force-graph-4'), &#xD;&#xA;                {&#xD;&#xA;                        extraRenderers: [&#xD;&#xA;                                new CSS2DRenderer()&#xD;&#xA;                        ]&#xD;&#xA;                })&#xD;&#xA;                .graphData({&quot;nodes&quot;: [&#xA;          {&#xA;            &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EDataType.gif&quot;,&#xA;            &quot;name&quot;: &quot;EString&quot;,&#xA;            &quot;id&quot;: &quot;EString@http://www.eclipse.org/emf/2002/Ecore&quot;,&#xA;            &quot;value&quot;: [{&quot;externalLink&quot;: &quot;index.html&quot;}],&#xA;            &quot;group&quot;: &quot;http://www.eclipse.org/emf/2002/Ecore&quot;&#xA;          },&#xA;          {&#xA;            &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&#xA;            &quot;size&quot;: 3,&#xA;            &quot;name&quot;: &quot;MyClass&quot;,&#xA;            &quot;id&quot;: &quot;MyClass@ecore://myontology.nasdanika.org&quot;,&#xA;            &quot;value&quot;: [{&quot;externalLink&quot;: &quot;&quot;}],&#xA;            &quot;group&quot;: &quot;ecore://myontology.nasdanika.org&quot;&#xA;          }&#xA;        ]})&#xD;&#xA;                .nodeAutoColorBy('group')&#xD;&#xA;                .nodeVal('size')&#xD;&#xA;                .linkDirectionalArrowLength(2.5)&#xD;&#xA;                .linkDirectionalArrowRelPos(1)&#xD;&#xA;                .linkCurvature('curvature')&#xD;&#xA;                .linkCurveRotation('rotation')&#xD;&#xA;                .linkAutoColorBy('group')&#xD;&#xA;                .onNodeClick((node, event) => {&#xA;       if (node.lastClick) {&#xA;        if (event.timeStamp - node.lastClick &lt; 500) {&#xA;&#x9;&#x9;&#x9;if (Array.isArray(node.value) &amp;&amp; node.value.length > 0) {&#xA;&#x9;&#x9;&#x9;&#x9;if (node.value[0].link) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(node.value[0].link, &quot;_self&quot;);&#xA;&#x9;&#x9;&#x9;&#x9;} else if (node.value[0].externalLink) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(node.value[0].externalLink);&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;delete node.lastClick;&#xA;&#x9;&#x9;} else {&#xA;&#x9;&#x9;&#x9;node.lastClick = event.timeStamp;&#xA;&#x9;&#x9;}&#xA;&#x9;} else {&#xA;&#x9;&#x9;node.lastClick = event.timeStamp;&#xA;&#x9;}&#xA;   })&#xD;&#xA;                .nodeThreeObject(node => {&#xA;        const nodeEl = document.createElement('div');&#xA;        nodeEl.textContent = node.name;&#xA;        nodeEl.style.color = node.color;&#xA;        nodeEl.className = 'node-label';&#xA;        return new CSS2DObject(nodeEl);&#xA;      })&#xD;&#xA;                .nodeThreeObjectExtend(true)&#xD;&#xA;                .linkThreeObject(link => {&#xA;         // extend link with text sprite&#xA;         if (link.name &amp;&amp; !link.curvature) {&#xA;           const sprite = new SpriteText(link.name);&#xA;           sprite.color = 'lightgrey';&#xA;           sprite.textHeight = 1.5;&#xA;           return sprite;&#xA;         }&#xA;       })&#xD;&#xA;                .linkPositionUpdate((sprite, { start, end }) => {&#xA;&#x9;&#x9;if (sprite) {&#xA;          const pos = Object.assign(...['x', 'y', 'z'].map(c => ({&#xA;            [c]: start[c] + (end[c] - start[c]) / 1.3&#xA;          })));&#xA;&#xA;          // Position sprite&#xA;          Object.assign(sprite.position, pos);&#xA;        }&#xA;       })&#xD;&#xA;                .linkThreeObjectExtend(true)&#xD;&#xA;                .onNodeDragEnd(node => {&#xA;          node.fx = node.x;&#xA;          node.fy = node.y;&#xA;          node.fz = node.z;&#xA;        })&#xA;&lt;/script>&#xA;"/>
        <decorator xsi:type="org.nasdanika.models.app:Link" uuid="fe51ee05-98f6-4bfc-9525-6de9452a3fb5" id="b7c8da03-e8ff-4bad-8f4e-c328a9c6e188" icon="far fa-question-circle" tooltip="A live force-layout graph of package classifiers showing detailed relationships between them">
          <attributes key="style">
            <value xsi:type="org.nasdanika.exec.content:Text" uuid="72d3f5c1-9842-46fc-a4f7-3b94fa1aaf64" content="vertical-align:super;font-size:x-small;margin-left:0.2em"/>
          </attributes>
          <modal uuid="0cbb5a09-dc4d-446b-83a8-638357736aa9">
            <body uuid="5cba34dc-7199-425d-a56a-cc6c3ae5267f">
              <content xsi:type="org.nasdanika.exec.content:Text" uuid="25eb2aa9-1527-4078-8e4e-aad65ae854a6" content="Hover mouse over nodes elements to display tooltips.&#xA;Double-click on nodes to navigate go documentation.&#xA;Left click - rotate.&#xA;Mouse wheel - zoom.&#xA;Right click - pan.&#xA;Drag to rearrange.&#xA;"/>
            </body>
          </modal>
        </decorator>
      </children>
