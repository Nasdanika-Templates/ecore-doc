e://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&quot;id&quot;:&quot;AbstractCollection@urn:mypackage&quot;,&quot;name&quot;:&quot;AbstractCollection&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/AbstractCollection/index.html&quot;},&quot;x&quot;:211.30001718687012,&quot;y&quot;:187.6034942613631,&quot;category&quot;:0},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EInterface.gif&quot;,&quot;id&quot;:&quot;Collection@urn:mypackage&quot;,&quot;name&quot;:&quot;Collection&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/Collection/index.html&quot;},&quot;x&quot;:19.881390169071093,&quot;y&quot;:121.56944177501316,&quot;category&quot;:0},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EInterface.gif&quot;,&quot;id&quot;:&quot;List@urn:mypackage&quot;,&quot;name&quot;:&quot;List&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/List/index.html&quot;},&quot;x&quot;:173.808254191037,&quot;y&quot;:0.0,&quot;category&quot;:0},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EEnum.gif&quot;,&quot;id&quot;:&quot;TimeUnit@urn:mypackage&quot;,&quot;name&quot;:&quot;TimeUnit&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/TimeUnit/index.html&quot;},&quot;x&quot;:1000.0,&quot;y&quot;:800.0,&quot;category&quot;:0}],&quot;symbolSize&quot;:20,&quot;roam&quot;:true,&quot;layout&quot;:&quot;circular&quot;,&quot;links&quot;:[{&quot;source&quot;:0,&quot;target&quot;:2},{&quot;source&quot;:0,&quot;target&quot;:3},{&quot;source&quot;:0,&quot;target&quot;:5},{&quot;source&quot;:2,&quot;target&quot;:0},{&quot;source&quot;:2,&quot;target&quot;:1},{&quot;source&quot;:3,&quot;target&quot;:0},{&quot;source&quot;:3,&quot;target&quot;:4},{&quot;source&quot;:4,&quot;target&quot;:3},{&quot;source&quot;:4,&quot;target&quot;:5},{&quot;source&quot;:5,&quot;target&quot;:0},{&quot;source&quot;:5,&quot;target&quot;:4}],&quot;categories&quot;:[{&quot;name&quot;:&quot;mypackage&quot;},{&quot;name&quot;:&quot;ecore&quot;}],&quot;draggable&quot;:true,&quot;label&quot;:{&quot;show&quot;:true,&quot;position&quot;:&quot;right&quot;},&quot;lineStyle&quot;:{&quot;color&quot;:&quot;source&quot;,&quot;curveness&quot;:0.3},&quot;circular&quot;:{&quot;rotateLabel&quot;:true}}]};&#xA;&#x9;&#x9;option.tooltip = {};&#xA;&#x9;&#x9;option.series[0].tooltip = {&#xA;&#x9;&#x9;&#x9;formatter: function(arg) {&#xA;&#x9;&#x9;&#x9;&#x9;return arg.value ? arg.value.description : null;&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;};&#xA;&#x9;&#x9;myChart.setOption(option);&#xA;&#x9;&#x9;myChart.on(&quot;dblclick&quot;, function(params) {&#xA;&#x9;&#x9;&#x9;if (params.value) {&#xA;&#x9;&#x9;&#x9;&#x9;if (params.value.link) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(params.value.link, &quot;_self&quot;);&#xA;&#x9;&#x9;&#x9;&#x9;} else if (params.value.externalLink) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(params.value.externalLink);&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;});&#xA;&#x9;&#x9;window.addEventListener(&quot;resize&quot;, myChart.resize);&#xA;&#x9;});&#xA;&lt;/script>&#xA;"/>
