          <value xsi:type="org.nasdanika.exec.content:Text" uuid="c3450402-3505-4fef-834f-218fbc43583f" content="vertical-align:super;font-size:x-small;margin-left:0.2em"/>
        </attributes>
        <modal uuid="7e6f7550-14e0-4c03-bbe9-a400c50853a9">
          <body uuid="afd09261-1df3-45a9-ac8a-72a4a2f01fa7">
            <content xsi:type="org.nasdanika.exec.content:Text" uuid="bceff1e2-d205-4e2c-850f-fe5246cc78a7" content="Hover mouse over nodes elements to display tooltips.&#xA;Double-click on nodes to navigate go documentation.&#xA;Drag to rearrange, nodes will not stay in place once released.&#xA;"/>
          </body>
        </modal>
      </decorator>
    </children>
    <children xsi:type="org.nasdanika.models.app:Action" uuid="fbfaccef-f494-4876-b66c-ba3d8d55b68b" id="58251fa6-5d72-4b1c-88bb-9b1f5a77ebee" text="Force Graph 3D" location="force-layout-graph-3d.html">
      <content xsi:type="org.nasdanika.exec.content:Text" uuid="790fed60-9e5f-46a0-8f5b-56554be65bcd" content="&lt;div id=&quot;force-graph-24&quot; class=&quot;row&quot; style=&quot;height:70vh;width:100%&quot;>&#xA;&lt;/div>&#xA;&lt;script type=&quot;module&quot;>&#xA;&#x9;import { CSS2DRenderer, CSS2DObject } from 'three/addons/renderers/CSS2DRenderer.js';&#xA;&#x9;import SpriteText from &quot;https://cdn.jsdelivr.net/npm/three-spritetext@1.10.0/dist/three-spritetext.mjs&quot;;&#xA;&#xA;&#x9;        new ForceGraph3D(&#xD;&#xA;                document.getElementById('force-graph-24'), &#xD;&#xA;                {&#xD;&#xA;                        extraRenderers: [&#xD;&#xA;                                new CSS2DRenderer()&#xD;&#xA;                        ]&#xD;&#xA;                })&#xD;&#xA;                .graphData({&#xA;          &quot;nodes&quot;: [&#xA;            {&#xA;              &quot;name&quot;: &quot;ArrayList&quot;,&#xA;              &quot;id&quot;: &quot;ArrayList@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/ArrayList/index.html&quot;}]&#xA;            },&#xA;            {&#xA;              &quot;name&quot;: &quot;AbstractCollection&quot;,&#xA;              &quot;id&quot;: &quot;AbstractCollection@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/AbstractCollection/index.html&quot;}]&#xA;            },&#xA;            {&#xA;              &quot;name&quot;: &quot;List&quot;,&#xA;              &quot;id&quot;: &quot;List@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/List/index.html&quot;}]&#xA;            },&#xA;            {&#xA;              &quot;name&quot;: &quot;TimeUnit&quot;,&#xA;              &quot;id&quot;: &quot;TimeUnit@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/TimeUnit/index.html&quot;}]&#xA;            },&#xA;            {&#xA;              &quot;name&quot;: &quot;AbstractList&quot;,&#xA;              &quot;id&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/AbstractList/index.html&quot;}]&#xA;            },&#xA;            {&#xA;              &quot;name&quot;: &quot;Collection&quot;,&#xA;              &quot;id&quot;: &quot;Collection@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/Collection/index.html&quot;}]&#xA;            }&#xA;          ],&#xA;          &quot;links&quot;: [&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;ArrayList@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;AbstractCollection@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;AbstractCollection@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;Collection@urn:mypackage&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;List@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;List@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;Collection@urn:mypackage&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;AbstractCollection@urn:mypackage&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;ArrayList@urn:mypackage&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;List@urn:mypackage&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;Collection@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;AbstractCollection@urn:mypackage&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;Collection@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;List@urn:mypackage&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            }&#xA;          ]&#xA;        })&#xD;&#xA;                .nodeAutoColorBy('group')&#xD;&#xA;                .nodeVal('size')&#xD;&#xA;                .linkDirectionalArrowLength(2.5)&#xD;&#xA;                .linkDirectionalArrowRelPos(1)&#xD;&#xA;                .linkCurvature('curvature')&#xD;&#xA;                .linkCurveRotation('rotation')&#xD;&#xA;                .onNodeClick((node, event) => {&#xA;       if (node.lastClick) {&#xA;        if (event.timeStamp - node.lastClick &lt; 500) {&#xA;&#x9;&#x9;&#x9;if (Array.isArray(node.value) &amp;&amp; node.value.length > 0) {&#xA;&#x9;&#x9;&#x9;&#x9;if (node.value[0].link) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(node.value[0].link, &quot;_self&quot;);&#xA;&#x9;&#x9;&#x9;&#x9;} else if (node.value[0].externalLink) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(node.value[0].externalLink);&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;delete node.lastClick;&#xA;&#x9;&#x9;} else {&#xA;&#x9;&#x9;&#x9;node.lastClick = event.timeStamp;&#xA;&#x9;&#x9;}&#xA;&#x9;} else {&#xA;&#x9;&#x9;node.lastClick = event.timeStamp;&#xA;&#x9;}&#xA;   })&#xD;&#xA;                .nodeThreeObject(node => {&#xA;        const nodeEl = document.createElement('div');&#xA;        nodeEl.textContent = node.name;&#xA;        nodeEl.style.color = node.color;&#xA;        nodeEl.className = 'node-label';&#xA;        return new CSS2DObject(nodeEl);&#xA;      })&#xD;&#xA;                .nodeThreeObjectExtend(true)&#xD;&#xA;                .onNodeDragEnd(node => {&#xA;          node.fx = node.x;&#xA;          node.fy = node.y;&#xA;          node.fz = node.z;&#xA;        })&#xA;&lt;/script>&#xA;"/>
      <decorator xsi:type="org.nasdanika.models.app:Link" uuid="ebfcffe7-96fe-4552-a26a-515fafe17e1f" id="d54929da-59d2-4e6b-a334-69e514c44a4e" icon="far fa-question-circle" tooltip="A live force-layout graph of package classifiers showing relationships between them">
        <attributes key="style">
          <value xsi:type="org.nasdanika.exec.content:Text" uuid="07229b07-4fc7-4eaa-b8ba-47ab29b5ea8d" content="vertical-align:super;font-size:x-small;margin-left:0.2em"/>
        </attributes>
        <modal uuid="8fe52f7f-5959-4153-a8a3-088dca213ac8">
          <body uuid="8c45382a-57fa-4784-a3ad-341254e3475a">
            <content xsi:type="org.nasdanika.exec.content:Text" uuid="fd289bc7-6983-4d00-a7bb-71ada5d4409d" content="Hover mouse over nodes elements to display tooltips.&#xA;Double-click on nodes to navigate go documentation.&#xA;Left click - rotate.&#xA;Mouse wheel - zoom.&#xA;Right click - pan.&#xA;Drag to rearrange.&#xA;"/>
          </body>
        </modal>
      </decorator>
    </children>
    <children xsi:type="org.nasdanika.models.app:Action" uuid="bf65d809-95bb-44f0-953f-0e03f5987d13" id="08b01e86-84a7-43aa-a24c-3a9c8119ecdf" text="Force Graph 3D Detailed" location="force-layout-graph-3d-detailed.html">
      <content xsi:type="org.nasdanika.exec.content:Text" uuid="6911e04f-cac8-4f94-ab2a-d50299247dd6" content="&lt;div id=&quot;force-graph-25&quot; class=&quot;row&quot; style=&quot;height:70vh;width:100%&quot;>&#xA;&lt;/div>&#xA;&lt;script type=&quot;module&quot;>&#xA;&#x9;import { CSS2DRenderer, CSS2DObject } from 'three/addons/renderers/CSS2DRenderer.js';&#xA;&#x9;import SpriteText from &quot;https://cdn.jsdelivr.net/npm/three-spritetext@1.10.0/dist/three-spritetext.mjs&quot;;&#xA;&#xA;&#x9;        new ForceGraph3D(&#xD;&#xA;                document.getElementById('force-graph-25'), &#xD;&#xA;                {&#xD;&#xA;                        extraRenderers: [&#xD;&#xA;                                new CSS2DRenderer()&#xD;&#xA;                        ]&#xD;&#xA;                })&#xD;&#xA;                .graphData({&#xA;          &quot;nodes&quot;: [&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&#xA;              &quot;size&quot;: 3,&#xA;              &quot;name&quot;: &quot;ArrayList&quot;,&#xA;              &quot;id&quot;: &quot;ArrayList@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/ArrayList/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;urn:mypackage&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&#xA;              &quot;size&quot;: 3,&#xA;              &quot;name&quot;: &quot;AbstractCollection&quot;,&#xA;              &quot;id&quot;: &quot;AbstractCollection@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/AbstractCollection/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;urn:mypackage&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EInterface.gif&quot;,&#xA;              &quot;size&quot;: 3,&#xA;              &quot;name&quot;: &quot;List&quot;,&#xA;              &quot;id&quot;: &quot;List@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/List/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;urn:mypackage&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EEnum.gif&quot;,&#xA;              &quot;name&quot;: &quot;TimeUnit&quot;,&#xA;              &quot;id&quot;: &quot;TimeUnit@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/TimeUnit/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;urn:mypackage&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&#xA;              &quot;size&quot;: 3,&#xA;              &quot;name&quot;: &quot;AbstractList&quot;,&#xA;              &quot;id&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/AbstractList/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;urn:mypackage&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EInterface.gif&quot;,&#xA;              &quot;size&quot;: 3,&#xA;              &quot;name&quot;: &quot;Collection&quot;,&#xA;              &quot;id&quot;: &quot;Collection@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/Collection/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;urn:mypackage&quot;&#xA;            }&#xA;          ],&#xA;          &quot;links&quot;: [&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;ArrayList@urn:mypackage&quot;,&#xA;              &quot;group&quot;: &quot;inheritance&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;List@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;group&quot;: &quot;inheritance&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;AbstractCollection@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;group&quot;: &quot;inheritance&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;Collection@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;AbstractCollection@urn:mypackage&quot;,&#xA;              &quot;group&quot;: &quot;inheritance&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;Collection@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;List@urn:mypackage&quot;,&#xA;              &quot;group&quot;: &quot;inheritance&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            }&#xA;          ]&#xA;        })&#xD;&#xA;                .nodeAutoColorBy('group')&#xD;&#xA;                .nodeVal('size')&#xD;&#xA;                .linkDirectionalArrowLength(2.5)&#xD;&#xA;                .linkDirectionalArrowRelPos(1)&#xD;&#xA;                .linkCurvature('curvature')&#xD;&#xA;                .linkCurveRotation('rotation')&#xD;&#xA;                .linkAutoColorBy('group')&#xD;&#xA;                .onNodeClick((node, event) => {&#xA;       if (node.lastClick) {&#xA;        if (event.timeStamp - node.lastClick &lt; 500) {&#xA;&#x9;&#x9;&#x9;if (Array.isArray(node.value) &amp;&amp; node.value.length > 0) {&#xA;&#x9;&#x9;&#x9;&#x9;if (node.value[0].link) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(node.value[0].link, &quot;_self&quot;);&#xA;&#x9;&#x9;&#x9;&#x9;} else if (node.value[0].externalLink) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(node.value[0].externalLink);&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;delete node.lastClick;&#xA;&#x9;&#x9;} else {&#xA;&#x9;&#x9;&#x9;node.lastClick = event.timeStamp;&#xA;&#x9;&#x9;}&#xA;&#x9;} else {&#xA;&#x9;&#x9;node.lastClick = event.timeStamp;&#xA;&#x9;}&#xA;   })&#xD;&#xA;                .nodeThreeObject(node => {&#xA;        const nodeEl = document.createElement('div');&#xA;        nodeEl.textContent = node.name;&#xA;        nodeEl.style.color = node.color;&#xA;        nodeEl.className = 'node-label';&#xA;        return new CSS2DObject(nodeEl);&#xA;      })&#xD;&#xA;                .nodeThreeObjectExtend(true)&#xD;&#xA;                .linkThreeObject(link => {&#xA;         // extend link with text sprite&#xA;         if (link.name &amp;&amp; !link.curvature) {&#xA;           const sprite = new SpriteText(link.name);&#xA;           sprite.color = 'lightgrey';&#xA;           sprite.textHeight = 1.5;&#xA;           return sprite;&#xA;         }&#xA;       })&#xD;&#xA;                .linkPositionUpdate((sprite, { start, end }) => {&#xA;&#x9;&#x9;if (sprite) {&#xA;          const pos = Object.assign(...['x', 'y', 'z'].map(c => ({&#xA;            [c]: start[c] + (end[c] - start[c]) / 1.3&#xA;          })));&#xA;&#xA;          // Position sprite&#xA;          Object.assign(sprite.position, pos);&#xA;        }&#xA;       })&#xD;&#xA;                .linkThreeObjectExtend(true)&#xD;&#xA;                .onNodeDragEnd(node => {&#xA;          node.fx = node.x;&#xA;          node.fy = node.y;&#xA;          node.fz = node.z;&#xA;        })&#xA;&lt;/script>&#xA;"/>
      <decorator xsi:type="org.nasdanika.models.app:Link" uuid="51fb4bea-e05b-4e68-89d9-e9d5c06662f6" id="ef9b59b3-18c0-4d14-9f46-08f752f78fc0" icon="far fa-question-circle" tooltip="A live force-layout graph of package classifiers showing detailed relationships between them">
        <attributes key="style">
          <value xsi:type="org.nasdanika.exec.content:Text" uuid="0bf4e726-f9a0-4f90-bc23-f19219b295b5" content="vertical-align:super;font-size:x-small;margin-left:0.2em"/>
        </attributes>
        <modal uuid="1760bcc8-5da0-482b-a9a9-675c8718096d">
          <body uuid="ff3397ca-2a16-4b75-bda3-ff9d33579a52">
