    <children xsi:type="org.nasdanika.models.app:Action" uuid="3fd09706-b331-4241-84d3-f473df56a234" id="88789c6e-da42-4606-99fa-1a65e3c6e758" text="Force Graph" location="force-layout-graph-with-dependencies-and-subpackages.html">
      <content xsi:type="org.nasdanika.exec.content:Text" uuid="4e365089-1de0-48b2-8283-4c0ac4d2c168" content="&lt;div id=&quot;graph-container-28&quot; class=&quot;row&quot; style=&quot;height:70vh;width:100%&quot;>&#xA;&lt;/div>&#xA;&lt;script type=&quot;text/javascript&quot;>&#xA;&#x9;$(document).ready(function() {&#xA;&#x9;&#x9;var dom = document.getElementById(&quot;graph-container-28&quot;);&#xA;&#x9;&#x9;var myChart = echarts.init(dom, null, {&#xA;&#x9;&#x9;&#x9;render: &quot;canvas&quot;,&#xA;&#x9;&#x9;&#x9;useDirtyRect: false&#xA;&#x9;&#x9;});&#xA;&#x9;&#x9;var option = {&quot;legend&quot;:{},&quot;series&quot;:[{&quot;type&quot;:&quot;graph&quot;,&quot;emphasis&quot;:{&quot;focus&quot;:&quot;adjacency&quot;},&quot;data&quot;:[{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&quot;id&quot;:&quot;AbstractList@urn:mypackage&quot;,&quot;name&quot;:&quot;AbstractList&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/AbstractList/index.html&quot;},&quot;x&quot;:782.9844036078922,&quot;y&quot;:220.86368498436292,&quot;category&quot;:0},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EDataType.gif&quot;,&quot;id&quot;:&quot;EJavaObject@http://www.eclipse.org/emf/2002/Ecore&quot;,&quot;name&quot;:&quot;EJavaObject&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;index.html&quot;},&quot;x&quot;:365.0034132476563,&quot;y&quot;:0.0,&quot;category&quot;:1},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&quot;id&quot;:&quot;ArrayList@urn:mypackage&quot;,&quot;name&quot;:&quot;ArrayList&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/ArrayList/index.html&quot;},&quot;x&quot;:571.3152384481666,&quot;y&quot;:64.68856886287446,&quot;category&quot;:0},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&quot;id&quot;:&quot;AbstractCollection@urn:mypackage&quot;,&quot;name&quot;:&quot;AbstractCollection&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/AbstractCollection/index.html&quot;},&quot;x&quot;:827.9578081008042,&quot;y&quot;:439.2748065164484,&quot;category&quot;:0},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EInterface.gif&quot;,&quot;id&quot;:&quot;Collection@urn:mypackage&quot;,&quot;name&quot;:&quot;Collection&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/Collection/index.html&quot;},&quot;x&quot;:1000.0,&quot;y&quot;:495.4408585824361,&quot;category&quot;:0},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EInterface.gif&quot;,&quot;id&quot;:&quot;List@urn:mypackage&quot;,&quot;name&quot;:&quot;List&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/List/index.html&quot;},&quot;x&quot;:1000.0,&quot;y&quot;:291.4121640009225,&quot;category&quot;:0},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EEnum.gif&quot;,&quot;id&quot;:&quot;TimeUnit@urn:mypackage&quot;,&quot;name&quot;:&quot;TimeUnit&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/TimeUnit/index.html&quot;},&quot;x&quot;:0.0,&quot;y&quot;:800.0,&quot;category&quot;:0}],&quot;symbolSize&quot;:20,&quot;roam&quot;:true,&quot;layout&quot;:&quot;force&quot;,&quot;links&quot;:[{&quot;source&quot;:0,&quot;target&quot;:2},{&quot;source&quot;:0,&quot;target&quot;:3},{&quot;source&quot;:0,&quot;target&quot;:5},{&quot;source&quot;:2,&quot;target&quot;:0},{&quot;source&quot;:2,&quot;target&quot;:1},{&quot;source&quot;:3,&quot;target&quot;:0},{&quot;source&quot;:3,&quot;target&quot;:4},{&quot;source&quot;:4,&quot;target&quot;:3},{&quot;source&quot;:4,&quot;target&quot;:5},{&quot;source&quot;:5,&quot;target&quot;:0},{&quot;source&quot;:5,&quot;target&quot;:4}],&quot;categories&quot;:[{&quot;name&quot;:&quot;mypackage&quot;},{&quot;name&quot;:&quot;ecore&quot;}],&quot;draggable&quot;:true,&quot;label&quot;:{&quot;show&quot;:true,&quot;position&quot;:&quot;right&quot;},&quot;lineStyle&quot;:{&quot;color&quot;:&quot;source&quot;,&quot;curveness&quot;:0},&quot;force&quot;:{&quot;repulsion&quot;:200,&quot;gravity&quot;:0.1,&quot;edgeLength&quot;:200}}]};&#xA;&#x9;&#x9;option.tooltip = {};&#xA;&#x9;&#x9;option.series[0].tooltip = {&#xA;&#x9;&#x9;&#x9;formatter: function(arg) {&#xA;&#x9;&#x9;&#x9;&#x9;return arg.value ? arg.value.description : null;&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;};&#xA;&#x9;&#x9;myChart.setOption(option);&#xA;&#x9;&#x9;myChart.on(&quot;dblclick&quot;, function(params) {&#xA;&#x9;&#x9;&#x9;if (params.value) {&#xA;&#x9;&#x9;&#x9;&#x9;if (params.value.link) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(params.value.link, &quot;_self&quot;);&#xA;&#x9;&#x9;&#x9;&#x9;} else if (params.value.externalLink) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(params.value.externalLink);&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;});&#xA;&#x9;&#x9;window.addEventListener(&quot;resize&quot;, myChart.resize);&#xA;&#x9;});&#xA;&lt;/script>&#xA;"/>
      <decorator xsi:type="org.nasdanika.models.app:Link" uuid="20b12bea-cf71-410e-a3bd-1df0d0766398" id="e194b850-b075-4cbd-90fe-c914869ec15a" icon="far fa-question-circle" tooltip="A live force-layout graph of package classifiers showing relationships between them">
        <attributes key="style">
          <value xsi:type="org.nasdanika.exec.content:Text" uuid="8c422a11-f6be-454c-8ce7-c402e5e719cc" content="vertical-align:super;font-size:x-small;margin-left:0.2em"/>
        </attributes>
        <modal uuid="774750ab-a684-4ee1-8175-76ab267248b7">
          <body uuid="7207cacf-7d24-4bba-b89b-1c36cfba045b">
            <content xsi:type="org.nasdanika.exec.content:Text" uuid="7f1055ab-14f7-409b-94ef-922def6adcca" content="Hover mouse over nodes elements to display tooltips.&#xA;Double-click on nodes to navigate go documentation.&#xA;Drag to rearrange, nodes will not stay in place once released.&#xA;"/>
