        <content xsi:type="org.nasdanika.exec.content:Text" uuid="5c2066fc-f5ab-422f-aab9-6312d181a3e3" content="&lt;div id=&quot;force-graph-4&quot; class=&quot;row&quot; style=&quot;height:70vh;width:100%&quot;>&#xA;&lt;/div>&#xA;&lt;script type=&quot;module&quot;>&#xA;&#x9;import { CSS2DRenderer, CSS2DObject } from 'three/addons/renderers/CSS2DRenderer.js';&#xA;&#x9;import SpriteText from &quot;https://cdn.jsdelivr.net/npm/three-spritetext@1.10.0/dist/three-spritetext.mjs&quot;;&#xA;&#xA;&#x9;        new ForceGraph3D(&#xD;&#xA;                document.getElementById('force-graph-4'), &#xD;&#xA;                {&#xD;&#xA;                        extraRenderers: [&#xD;&#xA;                                new CSS2DRenderer()&#xD;&#xA;                        ]&#xD;&#xA;                })&#xD;&#xA;                .graphData({&#xA;          &quot;nodes&quot;: [&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&#xA;              &quot;size&quot;: 3,&#xA;              &quot;name&quot;: &quot;AbstractList&quot;,&#xA;              &quot;id&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;&quot;}],&#xA;              &quot;group&quot;: &quot;urn:mypackage&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&#xA;              &quot;size&quot;: 3,&#xA;              &quot;name&quot;: &quot;AbstractCollection&quot;,&#xA;              &quot;id&quot;: &quot;AbstractCollection@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;../AbstractCollection/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;urn:mypackage&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&#xA;              &quot;size&quot;: 3,&#xA;              &quot;name&quot;: &quot;ArrayList&quot;,&#xA;              &quot;id&quot;: &quot;ArrayList@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;../ArrayList/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;urn:mypackage&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EInterface.gif&quot;,&#xA;              &quot;size&quot;: 3,&#xA;              &quot;name&quot;: &quot;List&quot;,&#xA;              &quot;id&quot;: &quot;List@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;../List/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;urn:mypackage&quot;&#xA;            }&#xA;          ],&#xA;          &quot;links&quot;: [&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;AbstractCollection@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;group&quot;: &quot;inheritance&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;ArrayList@urn:mypackage&quot;,&#xA;              &quot;group&quot;: &quot;inheritance&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;List@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;group&quot;: &quot;inheritance&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            }&#xA;          ]&#xA;        })&#xD;&#xA;                .nodeAutoColorBy('group')&#xD;&#xA;                .nodeVal('size')&#xD;&#xA;                .linkDirectionalArrowLength(2.5)&#xD;&#xA;                .linkDirectionalArrowRelPos(1)&#xD;&#xA;                .linkCurvature('curvature')&#xD;&#xA;                .linkCurveRotation('rotation')&#xD;&#xA;                .linkAutoColorBy('group')&#xD;&#xA;                .onNodeClick((node, event) => {&#xA;       if (node.lastClick) {&#xA;        if (event.timeStamp - node.lastClick &lt; 500) {&#xA;&#x9;&#x9;&#x9;if (Array.isArray(node.value) &amp;&amp; node.value.length > 0) {&#xA;&#x9;&#x9;&#x9;&#x9;if (node.value[0].link) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(node.value[0].link, &quot;_self&quot;);&#xA;&#x9;&#x9;&#x9;&#x9;} else if (node.value[0].externalLink) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(node.value[0].externalLink);&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;delete node.lastClick;&#xA;&#x9;&#x9;} else {&#xA;&#x9;&#x9;&#x9;node.lastClick = event.timeStamp;&#xA;&#x9;&#x9;}&#xA;&#x9;} else {&#xA;&#x9;&#x9;node.lastClick = event.timeStamp;&#xA;&#x9;}&#xA;   })&#xD;&#xA;                .nodeThreeObject(node => {&#xA;        const nodeEl = document.createElement('div');&#xA;        nodeEl.textContent = node.name;&#xA;        nodeEl.style.color = node.color;&#xA;        nodeEl.className = 'node-label';&#xA;        return new CSS2DObject(nodeEl);&#xA;      })&#xD;&#xA;                .nodeThreeObjectExtend(true)&#xD;&#xA;                .linkThreeObject(link => {&#xA;         // extend link with text sprite&#xA;         if (link.name &amp;&amp; !link.curvature) {&#xA;           const sprite = new SpriteText(link.name);&#xA;           sprite.color = 'lightgrey';&#xA;           sprite.textHeight = 1.5;&#xA;           return sprite;&#xA;         }&#xA;       })&#xD;&#xA;                .linkPositionUpdate((sprite, { start, end }) => {&#xA;&#x9;&#x9;if (sprite) {&#xA;          const pos = Object.assign(...['x', 'y', 'z'].map(c => ({&#xA;            [c]: start[c] + (end[c] - start[c]) / 1.3&#xA;          })));&#xA;&#xA;          // Position sprite&#xA;          Object.assign(sprite.position, pos);&#xA;        }&#xA;       })&#xD;&#xA;                .linkThreeObjectExtend(true)&#xD;&#xA;                .onNodeDragEnd(node => {&#xA;          node.fx = node.x;&#xA;          node.fy = node.y;&#xA;          node.fz = node.z;&#xA;        })&#xA;&lt;/script>&#xA;"/>
        <decorator xsi:type="org.nasdanika.models.app:Link" uuid="6c7b5795-aed4-4c56-90f1-34713d8a482a" id="3023e5f4-04f7-471b-b8d0-ce72fca4eeef" icon="far fa-question-circle" tooltip="A live force-layout graph of package classifiers showing detailed relationships between them">
          <attributes key="style">
            <value xsi:type="org.nasdanika.exec.content:Text" uuid="6279f134-ebc1-4718-bc0b-784ddfaa1351" content="vertical-align:super;font-size:x-small;margin-left:0.2em"/>
          </attributes>
          <modal uuid="de384e6c-8c50-448a-a37f-a2d7c4f1f6fe">
            <body uuid="6e36d854-ba60-44e0-bb45-0deeb1eda549">
              <content xsi:type="org.nasdanika.exec.content:Text" uuid="c72faaab-ee4d-47b2-8157-d630d19c53b2" content="Hover mouse over nodes elements to display tooltips.&#xA;Double-click on nodes to navigate go documentation.&#xA;Left click - rotate.&#xA;Mouse wheel - zoom.&#xA;Right click - pan.&#xA;Drag to rearrange.&#xA;"/>
            </body>
          </modal>
        </decorator>
      </children>
