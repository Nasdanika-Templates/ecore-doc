      <content xsi:type="org.nasdanika.exec.content:Text" uuid="be370ae2-eb37-48e5-a4b2-a6e0779a9484" content="&lt;div id=&quot;graph-container-21&quot; class=&quot;row&quot; style=&quot;height:70vh;width:100%&quot;>&#xA;&lt;/div>&#xA;&lt;script type=&quot;text/javascript&quot;>&#xA;&#x9;$(document).ready(function() {&#xA;&#x9;&#x9;var dom = document.getElementById(&quot;graph-container-21&quot;);&#xA;&#x9;&#x9;var myChart = echarts.init(dom, null, {&#xA;&#x9;&#x9;&#x9;render: &quot;canvas&quot;,&#xA;&#x9;&#x9;&#x9;useDirtyRect: false&#xA;&#x9;&#x9;});&#xA;&#x9;&#x9;var option = {&quot;series&quot;:[{&quot;type&quot;:&quot;graph&quot;,&quot;emphasis&quot;:{&quot;focus&quot;:&quot;adjacency&quot;},&quot;data&quot;:[{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&quot;id&quot;:&quot;ArrayList@urn:mypackage&quot;,&quot;name&quot;:&quot;ArrayList&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/ArrayList/index.html&quot;},&quot;x&quot;:1000.0,&quot;y&quot;:800.0},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&quot;id&quot;:&quot;AbstractCollection@urn:mypackage&quot;,&quot;name&quot;:&quot;AbstractCollection&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/AbstractCollection/index.html&quot;},&quot;x&quot;:557.1284730635055,&quot;y&quot;:800.0},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EInterface.gif&quot;,&quot;id&quot;:&quot;List@urn:mypackage&quot;,&quot;name&quot;:&quot;List&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/List/index.html&quot;},&quot;x&quot;:631.5890324565713,&quot;y&quot;:570.5283708555437},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EEnum.gif&quot;,&quot;id&quot;:&quot;TimeUnit@urn:mypackage&quot;,&quot;name&quot;:&quot;TimeUnit&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/TimeUnit/index.html&quot;},&quot;x&quot;:0.0,&quot;y&quot;:0.0},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&quot;id&quot;:&quot;AbstractList@urn:mypackage&quot;,&quot;name&quot;:&quot;AbstractList&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/AbstractList/index.html&quot;},&quot;x&quot;:780.9824914278346,&quot;y&quot;:745.9787691799174},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EInterface.gif&quot;,&quot;id&quot;:&quot;Collection@urn:mypackage&quot;,&quot;name&quot;:&quot;Collection&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/Collection/index.html&quot;},&quot;x&quot;:429.4844023995994,&quot;y&quot;:647.7186467508766}],&quot;symbolSize&quot;:20,&quot;roam&quot;:true,&quot;layout&quot;:&quot;none&quot;,&quot;links&quot;:[{&quot;source&quot;:0,&quot;target&quot;:4},{&quot;source&quot;:1,&quot;target&quot;:4},{&quot;source&quot;:1,&quot;target&quot;:5},{&quot;source&quot;:2,&quot;target&quot;:4},{&quot;source&quot;:2,&quot;target&quot;:5},{&quot;source&quot;:4,&quot;target&quot;:1},{&quot;source&quot;:4,&quot;target&quot;:0},{&quot;source&quot;:4,&quot;target&quot;:2},{&quot;source&quot;:5,&quot;target&quot;:1},{&quot;source&quot;:5,&quot;target&quot;:2}],&quot;draggable&quot;:true,&quot;label&quot;:{&quot;show&quot;:true,&quot;position&quot;:&quot;right&quot;},&quot;lineStyle&quot;:{&quot;color&quot;:&quot;source&quot;,&quot;curveness&quot;:0}}]};&#xA;&#x9;&#x9;option.tooltip = {};&#xA;&#x9;&#x9;option.series[0].tooltip = {&#xA;&#x9;&#x9;&#x9;formatter: function(arg) {&#xA;&#x9;&#x9;&#x9;&#x9;return arg.value ? arg.value.description : null;&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;};&#xA;&#x9;&#x9;myChart.setOption(option);&#xA;&#x9;&#x9;myChart.on(&quot;dblclick&quot;, function(params) {&#xA;&#x9;&#x9;&#x9;if (params.value) {&#xA;&#x9;&#x9;&#x9;&#x9;if (params.value.link) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(params.value.link, &quot;_self&quot;);&#xA;&#x9;&#x9;&#x9;&#x9;} else if (params.value.externalLink) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(params.value.externalLink);&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;});&#xA;&#x9;&#x9;window.addEventListener(&quot;resize&quot;, myChart.resize);&#xA;&#x9;});&#xA;&lt;/script>&#xA;"/>
