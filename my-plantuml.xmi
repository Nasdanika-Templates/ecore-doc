      <children xsi:type="org.nasdanika.models.app:Action" uuid="c89d2a2e-305a-4aac-8e9b-318820e9ebfd" id="fd68d95a-0525-4772-8eaa-39b21dc1fe48" text="Force Graph 3D" location="force-layout-graph-3d.html">
        <content xsi:type="org.nasdanika.exec.content:Text" uuid="efa12557-f990-4349-807e-d9285d3cfc31" content="&lt;div id=&quot;force-graph-12&quot; class=&quot;row&quot; style=&quot;height:70vh;width:100%&quot;>&#xA;&lt;/div>&#xA;&lt;script type=&quot;module&quot;>&#xA;&#x9;import { CSS2DRenderer, CSS2DObject } from 'three/addons/renderers/CSS2DRenderer.js';&#xA;&#x9;import SpriteText from &quot;https://cdn.jsdelivr.net/npm/three-spritetext@1.10.0/dist/three-spritetext.mjs&quot;;&#xA;&#xA;&#x9;        new ForceGraph3D(&#xD;&#xA;                document.getElementById('force-graph-12'), &#xD;&#xA;                {&#xD;&#xA;                        extraRenderers: [&#xD;&#xA;                                new CSS2DRenderer()&#xD;&#xA;                        ]&#xD;&#xA;                })&#xD;&#xA;                .graphData({&#xA;          &quot;nodes&quot;: [&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&#xA;              &quot;size&quot;: 3,&#xA;              &quot;name&quot;: &quot;AbstractList&quot;,&#xA;              &quot;id&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;../AbstractList/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;urn:mypackage&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EInterface.gif&quot;,&#xA;              &quot;size&quot;: 3,&#xA;              &quot;name&quot;: &quot;Collection&quot;,&#xA;              &quot;id&quot;: &quot;Collection@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;../Collection/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;urn:mypackage&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EInterface.gif&quot;,&#xA;              &quot;size&quot;: 3,&#xA;              &quot;name&quot;: &quot;List&quot;,&#xA;              &quot;id&quot;: &quot;List@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;&quot;}],&#xA;              &quot;group&quot;: &quot;urn:mypackage&quot;&#xA;            }&#xA;          ],&#xA;          &quot;links&quot;: [&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;List@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;group&quot;: &quot;inheritance&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;Collection@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;List@urn:mypackage&quot;,&#xA;              &quot;group&quot;: &quot;inheritance&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            }&#xA;          ]&#xA;        })&#xD;&#xA;                .nodeAutoColorBy('group')&#xD;&#xA;                .nodeVal('size')&#xD;&#xA;                .linkDirectionalArrowLength(2.5)&#xD;&#xA;                .linkDirectionalArrowRelPos(1)&#xD;&#xA;                .linkCurvature('curvature')&#xD;&#xA;                .linkCurveRotation('rotation')&#xD;&#xA;                .linkAutoColorBy('group')&#xD;&#xA;                .onNodeClick((node, event) => {&#xA;       if (node.lastClick) {&#xA;        if (event.timeStamp - node.lastClick &lt; 500) {&#xA;&#x9;&#x9;&#x9;if (Array.isArray(node.value) &amp;&amp; node.value.length > 0) {&#xA;&#x9;&#x9;&#x9;&#x9;if (node.value[0].link) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(node.value[0].link, &quot;_self&quot;);&#xA;&#x9;&#x9;&#x9;&#x9;} else if (node.value[0].externalLink) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(node.value[0].externalLink);&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;delete node.lastClick;&#xA;&#x9;&#x9;} else {&#xA;&#x9;&#x9;&#x9;node.lastClick = event.timeStamp;&#xA;&#x9;&#x9;}&#xA;&#x9;} else {&#xA;&#x9;&#x9;node.lastClick = event.timeStamp;&#xA;&#x9;}&#xA;   })&#xD;&#xA;                .nodeThreeObject(node => {&#xA;        const nodeEl = document.createElement('div');&#xA;        nodeEl.textContent = node.name;&#xA;        nodeEl.style.color = node.color;&#xA;        nodeEl.className = 'node-label';&#xA;        return new CSS2DObject(nodeEl);&#xA;      })&#xD;&#xA;                .nodeThreeObjectExtend(true)&#xD;&#xA;                .linkThreeObject(link => {&#xA;         // extend link with text sprite&#xA;         if (link.name &amp;&amp; !link.curvature) {&#xA;           const sprite = new SpriteText(link.name);&#xA;           sprite.color = 'lightgrey';&#xA;           sprite.textHeight = 1.5;&#xA;           return sprite;&#xA;         }&#xA;       })&#xD;&#xA;                .linkPositionUpdate((sprite, { start, end }) => {&#xA;&#x9;&#x9;if (sprite) {&#xA;          const pos = Object.assign(...['x', 'y', 'z'].map(c => ({&#xA;            [c]: start[c] + (end[c] - start[c]) / 1.3&#xA;          })));&#xA;&#xA;          // Position sprite&#xA;          Object.assign(sprite.position, pos);&#xA;        }&#xA;       })&#xD;&#xA;                .linkThreeObjectExtend(true)&#xD;&#xA;                .onNodeDragEnd(node => {&#xA;          node.fx = node.x;&#xA;          node.fy = node.y;&#xA;          node.fz = node.z;&#xA;        })&#xA;&lt;/script>&#xA;"/>
        <decorator xsi:type="org.nasdanika.models.app:Link" uuid="0e3465c5-447b-4a3c-8a42-e2a5538d07ff" id="d7381100-8484-4b27-ad6e-8e1cefc452cb" icon="far fa-question-circle" tooltip="A live force-layout graph of package classifiers showing detailed relationships between them">
          <attributes key="style">
            <value xsi:type="org.nasdanika.exec.content:Text" uuid="1e49c594-cf79-44c6-ba8d-fea5f3ffb3e7" content="vertical-align:super;font-size:x-small;margin-left:0.2em"/>
          </attributes>
          <modal uuid="c2c876cb-2c52-40f7-b3ce-d5fc815aca15">
            <body uuid="f2664e27-0689-406c-a19b-8456deae7e1e">
              <content xsi:type="org.nasdanika.exec.content:Text" uuid="d47923cc-7b4e-4841-9bc8-f77715ca7f91" content="Hover mouse over nodes elements to display tooltips.&#xA;Double-click on nodes to navigate go documentation.&#xA;Left click - rotate.&#xA;Mouse wheel - zoom.&#xA;Right click - pan.&#xA;Drag to rearrange.&#xA;"/>
            </body>
          </modal>
        </decorator>
      </children>
      <decorator uuid="4be7ea9b-31ba-4c74-ba4c-85de253543f7" id="36d3bd4d-9855-4b1d-b3f6-44e9c6ac0fc9" icon="far fa-question-circle" tooltip="Graphs of package classifiers showing relationships between them">
