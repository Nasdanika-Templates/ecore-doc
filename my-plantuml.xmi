      <content xsi:type="org.nasdanika.exec.content:Text" uuid="3eb7e46d-8ac8-41cf-bae5-3c8dce9c650d" content="&lt;img src=&quot;data:image/png;base64, &quot; usemap=&quot;#plantuml_map_cb1f110e-2d68-419d-8618-c10b6ca0c147&quot;/>&#xD;&#xA;&lt;map id=&quot;plantuml_map_cb1f110e-2d68-419d-8618-c10b6ca0c147&quot; name=&quot;plantuml_map_cb1f110e-2d68-419d-8618-c10b6ca0c147&quot;>&#xA;&lt;area shape=&quot;rect&quot; id=&quot;id1&quot; href=&quot;../ArrayList/index.html&quot; title=&quot;../ArrayList/index.html&quot; alt=&quot;&quot; coords=&quot;23,41,79,59&quot;/>&#xA;&lt;area shape=&quot;rect&quot; id=&quot;id2&quot; href=&quot;../AbstractCollection/index.html&quot; title=&quot;../AbstractCollection/index.html&quot; alt=&quot;&quot; coords=&quot;13,283,127,301&quot;/>&#xA;&lt;area shape=&quot;rect&quot; id=&quot;id3&quot; href=&quot;../AbstractList/index.html&quot; title=&quot;../AbstractList/index.html&quot; alt=&quot;&quot; coords=&quot;17,7,123,80&quot;/>&#xA;&lt;area shape=&quot;rect&quot; id=&quot;id4&quot; href=&quot;../Collection/index.html&quot; title=&quot;../Collection/index.html&quot; alt=&quot;&quot; coords=&quot;7,249,133,322&quot;/>&#xA;&lt;/map>&#xA;"/>
