    <children xsi:type="org.nasdanika.models.app:Action" uuid="88bd4a44-1654-4acb-aa11-58b98dbd9772" id="5839c81d-ef83-47fa-87df-cae5f4936244" text="Force Graph 3D" location="force-layout-graph-3d-with-dependencies-and-subpackages.html">
      <content xsi:type="org.nasdanika.exec.content:Text" uuid="1305c441-764b-40f5-b187-12faad57397c" content="&lt;div id=&quot;force-graph29&quot; class=&quot;row&quot; style=&quot;height:70vh;width:100%&quot;>&#xA;&lt;/div>&#xA;&lt;script type=&quot;module&quot;>&#xA;&#x9;import { CSS2DRenderer, CSS2DObject } from 'three/addons/renderers/CSS2DRenderer.js';&#xA;&#x9;import SpriteText from &quot;https://cdn.jsdelivr.net/npm/three-spritetext@1.10.0/dist/three-spritetext.mjs&quot;;&#xA;&#xA;&#x9;        new ForceGraph3D(&#xD;&#xA;                document.getElementById('force-graph29'), &#xD;&#xA;                {&#xD;&#xA;                        extraRenderers: [&#xD;&#xA;                                new CSS2DRenderer()&#xD;&#xA;                        ]&#xD;&#xA;                })&#xD;&#xA;                .graphData({&#xA;          &quot;nodes&quot;: [&#xA;            {&#xA;              &quot;name&quot;: &quot;AbstractList&quot;,&#xA;              &quot;id&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/AbstractList/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;mypackage&quot;&#xA;            },&#xA;            {&#xA;              &quot;name&quot;: &quot;EJavaObject&quot;,&#xA;              &quot;id&quot;: &quot;EJavaObject@http://www.eclipse.org/emf/2002/Ecore&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;index.html&quot;}],&#xA;              &quot;group&quot;: &quot;ecore&quot;&#xA;            },&#xA;            {&#xA;              &quot;name&quot;: &quot;ArrayList&quot;,&#xA;              &quot;id&quot;: &quot;ArrayList@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/ArrayList/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;mypackage&quot;&#xA;            },&#xA;            {&#xA;              &quot;name&quot;: &quot;AbstractCollection&quot;,&#xA;              &quot;id&quot;: &quot;AbstractCollection@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/AbstractCollection/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;mypackage&quot;&#xA;            },&#xA;            {&#xA;              &quot;name&quot;: &quot;Collection&quot;,&#xA;              &quot;id&quot;: &quot;Collection@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/Collection/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;mypackage&quot;&#xA;            },&#xA;            {&#xA;              &quot;name&quot;: &quot;List&quot;,&#xA;              &quot;id&quot;: &quot;List@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/List/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;mypackage&quot;&#xA;            },&#xA;            {&#xA;              &quot;name&quot;: &quot;TimeUnit&quot;,&#xA;              &quot;id&quot;: &quot;TimeUnit@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/TimeUnit/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;mypackage&quot;&#xA;            }&#xA;          ],&#xA;          &quot;links&quot;: [&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;ArrayList@urn:mypackage&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;AbstractCollection@urn:mypackage&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;List@urn:mypackage&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;ArrayList@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;ArrayList@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;EJavaObject@http://www.eclipse.org/emf/2002/Ecore&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;AbstractCollection@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;AbstractCollection@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;Collection@urn:mypackage&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;Collection@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;AbstractCollection@urn:mypackage&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;Collection@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;List@urn:mypackage&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;List@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;List@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;Collection@urn:mypackage&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            }&#xA;          ]&#xA;        })&#xD;&#xA;                .nodeAutoColorBy('group')&#xD;&#xA;                .nodeVal('size')&#xD;&#xA;                .linkDirectionalArrowLength(2.5)&#xD;&#xA;                .linkDirectionalArrowRelPos(1)&#xD;&#xA;                .linkCurvature('curvature')&#xD;&#xA;                .linkCurveRotation('rotation')&#xD;&#xA;                .onNodeClick((node, event) => {&#xA;       if (node.lastClick) {&#xA;        if (event.timeStamp - node.lastClick &lt; 500) {&#xA;&#x9;&#x9;&#x9;if (Array.isArray(node.value) &amp;&amp; node.value.length > 0) {&#xA;&#x9;&#x9;&#x9;&#x9;if (node.value[0].link) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(node.value[0].link, &quot;_self&quot;);&#xA;&#x9;&#x9;&#x9;&#x9;} else if (node.value[0].externalLink) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(node.value[0].externalLink);&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;delete node.lastClick;&#xA;&#x9;&#x9;} else {&#xA;&#x9;&#x9;&#x9;node.lastClick = event.timeStamp;&#xA;&#x9;&#x9;}&#xA;&#x9;} else {&#xA;&#x9;&#x9;node.lastClick = event.timeStamp;&#xA;&#x9;}&#xA;   })&#xD;&#xA;                .nodeThreeObject(node => {&#xA;        const nodeEl = document.createElement('div');&#xA;        nodeEl.textContent = node.name;&#xA;        nodeEl.style.color = node.color;&#xA;        nodeEl.className = 'node-label';&#xA;        return new CSS2DObject(nodeEl);&#xA;      })&#xD;&#xA;                .nodeThreeObjectExtend(true)&#xD;&#xA;                .onNodeDragEnd(node => {&#xA;          node.fx = node.x;&#xA;          node.fy = node.y;&#xA;          node.fz = node.z;&#xA;        })&#xA;&lt;/script>&#xA;"/>
      <decorator xsi:type="org.nasdanika.models.app:Link" uuid="a25d1809-1d73-446b-962b-cb2fa1465838" id="7fd7dd9f-c33f-4170-8326-96f8cb28a122" icon="far fa-question-circle" tooltip="A live force-layout graph of package classifiers showing relationships between them">
        <attributes key="style">
          <value xsi:type="org.nasdanika.exec.content:Text" uuid="54898f27-dbe3-4321-93cd-20d51bf0e6d5" content="vertical-align:super;font-size:x-small;margin-left:0.2em"/>
        </attributes>
        <modal uuid="074c2574-6aec-4408-a396-9d4b89f6c09a">
          <body uuid="417588cb-02f9-44b8-bef7-69fff43d4d74">
            <content xsi:type="org.nasdanika.exec.content:Text" uuid="24cd690a-0d13-4648-8ea1-5980583a8b1a" content="Hover mouse over nodes elements to display tooltips.&#xA;Double-click on nodes to navigate go documentation.&#xA;Left click - rotate.&#xA;Mouse wheel - zoom.&#xA;Right click - pan.&#xA;Drag to rearrange.&#xA;"/>
          </body>
        </modal>
      </decorator>
    </children>
    <children xsi:type="org.nasdanika.models.app:Action" uuid="762aed58-b809-45e9-a26e-1e176448c68f" id="f64c356a-c700-437d-a94b-732709fd5458" text="Force Graph 3D Detailed" location="force-layout-graph-3d-with-dependencies-and-subpackages-detailed.html">
      <content xsi:type="org.nasdanika.exec.content:Text" uuid="cb1d03fc-e7fe-4a9f-8739-75145a363657" content="&lt;div id=&quot;force-graph-30&quot; class=&quot;row&quot; style=&quot;height:70vh;width:100%&quot;>&#xA;&lt;/div>&#xA;&lt;script type=&quot;module&quot;>&#xA;&#x9;import { CSS2DRenderer, CSS2DObject } from 'three/addons/renderers/CSS2DRenderer.js';&#xA;&#x9;import SpriteText from &quot;https://cdn.jsdelivr.net/npm/three-spritetext@1.10.0/dist/three-spritetext.mjs&quot;;&#xA;&#xA;&#x9;        new ForceGraph3D(&#xD;&#xA;                document.getElementById('force-graph-30'), &#xD;&#xA;                {&#xD;&#xA;                        extraRenderers: [&#xD;&#xA;                                new CSS2DRenderer()&#xD;&#xA;                        ]&#xD;&#xA;                })&#xD;&#xA;                .graphData({&#xA;          &quot;nodes&quot;: [&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&#xA;              &quot;size&quot;: 3,&#xA;              &quot;name&quot;: &quot;AbstractList&quot;,&#xA;              &quot;id&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/AbstractList/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;urn:mypackage&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EDataType.gif&quot;,&#xA;              &quot;name&quot;: &quot;EJavaObject&quot;,&#xA;              &quot;id&quot;: &quot;EJavaObject@http://www.eclipse.org/emf/2002/Ecore&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;index.html&quot;}],&#xA;              &quot;group&quot;: &quot;http://www.eclipse.org/emf/2002/Ecore&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&#xA;              &quot;size&quot;: 3,&#xA;              &quot;name&quot;: &quot;ArrayList&quot;,&#xA;              &quot;id&quot;: &quot;ArrayList@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/ArrayList/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;urn:mypackage&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&#xA;              &quot;size&quot;: 3,&#xA;              &quot;name&quot;: &quot;AbstractCollection&quot;,&#xA;              &quot;id&quot;: &quot;AbstractCollection@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/AbstractCollection/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;urn:mypackage&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EInterface.gif&quot;,&#xA;              &quot;size&quot;: 3,&#xA;              &quot;name&quot;: &quot;Collection&quot;,&#xA;              &quot;id&quot;: &quot;Collection@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/Collection/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;urn:mypackage&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EInterface.gif&quot;,&#xA;              &quot;size&quot;: 3,&#xA;              &quot;name&quot;: &quot;List&quot;,&#xA;              &quot;id&quot;: &quot;List@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/List/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;urn:mypackage&quot;&#xA;            },&#xA;            {&#xA;              &quot;image&quot;: &quot;https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EEnum.gif&quot;,&#xA;              &quot;name&quot;: &quot;TimeUnit&quot;,&#xA;              &quot;id&quot;: &quot;TimeUnit@urn:mypackage&quot;,&#xA;              &quot;value&quot;: [{&quot;externalLink&quot;: &quot;references/eClassifiers/TimeUnit/index.html&quot;}],&#xA;              &quot;group&quot;: &quot;urn:mypackage&quot;&#xA;            }&#xA;          ],&#xA;          &quot;links&quot;: [&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;ArrayList@urn:mypackage&quot;,&#xA;              &quot;group&quot;: &quot;inheritance&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;AbstractCollection@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;group&quot;: &quot;inheritance&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;Collection@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;AbstractCollection@urn:mypackage&quot;,&#xA;              &quot;group&quot;: &quot;inheritance&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;List@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;AbstractList@urn:mypackage&quot;,&#xA;              &quot;group&quot;: &quot;inheritance&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            },&#xA;            {&#xA;              &quot;rotation&quot;: 0,&#xA;              &quot;source&quot;: &quot;Collection@urn:mypackage&quot;,&#xA;              &quot;target&quot;: &quot;List@urn:mypackage&quot;,&#xA;              &quot;group&quot;: &quot;inheritance&quot;,&#xA;              &quot;curvature&quot;: 0&#xA;            }&#xA;          ]&#xA;        })&#xD;&#xA;                .nodeAutoColorBy('group')&#xD;&#xA;                .nodeVal('size')&#xD;&#xA;                .linkDirectionalArrowLength(2.5)&#xD;&#xA;                .linkDirectionalArrowRelPos(1)&#xD;&#xA;                .linkCurvature('curvature')&#xD;&#xA;                .linkCurveRotation('rotation')&#xD;&#xA;                .linkAutoColorBy('group')&#xD;&#xA;                .onNodeClick((node, event) => {&#xA;       if (node.lastClick) {&#xA;        if (event.timeStamp - node.lastClick &lt; 500) {&#xA;&#x9;&#x9;&#x9;if (Array.isArray(node.value) &amp;&amp; node.value.length > 0) {&#xA;&#x9;&#x9;&#x9;&#x9;if (node.value[0].link) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(node.value[0].link, &quot;_self&quot;);&#xA;&#x9;&#x9;&#x9;&#x9;} else if (node.value[0].externalLink) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(node.value[0].externalLink);&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;delete node.lastClick;&#xA;&#x9;&#x9;} else {&#xA;&#x9;&#x9;&#x9;node.lastClick = event.timeStamp;&#xA;&#x9;&#x9;}&#xA;&#x9;} else {&#xA;&#x9;&#x9;node.lastClick = event.timeStamp;&#xA;&#x9;}&#xA;   })&#xD;&#xA;                .nodeThreeObject(node => {&#xA;        const nodeEl = document.createElement('div');&#xA;        nodeEl.textContent = node.name;&#xA;        nodeEl.style.color = node.color;&#xA;        nodeEl.className = 'node-label';&#xA;        return new CSS2DObject(nodeEl);&#xA;      })&#xD;&#xA;                .nodeThreeObjectExtend(true)&#xD;&#xA;                .linkThreeObject(link => {&#xA;         // extend link with text sprite&#xA;         if (link.name &amp;&amp; !link.curvature) {&#xA;           const sprite = new SpriteText(link.name);&#xA;           sprite.color = 'lightgrey';&#xA;           sprite.textHeight = 1.5;&#xA;           return sprite;&#xA;         }&#xA;       })&#xD;&#xA;                .linkPositionUpdate((sprite, { start, end }) => {&#xA;&#x9;&#x9;if (sprite) {&#xA;          const pos = Object.assign(...['x', 'y', 'z'].map(c => ({&#xA;            [c]: start[c] + (end[c] - start[c]) / 1.3&#xA;          })));&#xA;&#xA;          // Position sprite&#xA;          Object.assign(sprite.position, pos);&#xA;        }&#xA;       })&#xD;&#xA;                .linkThreeObjectExtend(true)&#xD;&#xA;                .onNodeDragEnd(node => {&#xA;          node.fx = node.x;&#xA;          node.fy = node.y;&#xA;          node.fz = node.z;&#xA;        })&#xA;&lt;/script>&#xA;"/>
      <decorator xsi:type="org.nasdanika.models.app:Link" uuid="af388a0d-d5ce-4627-9eff-04aa200ed1e2" id="0b535e7b-3a51-4f4b-9fb1-4a29d1dd1184" icon="far fa-question-circle" tooltip="A live force-layout graph of package classifiers showing detailed relationships between them">
        <attributes key="style">
          <value xsi:type="org.nasdanika.exec.content:Text" uuid="2d137aa5-619f-4c48-a609-bd5f8c100b41" content="vertical-align:super;font-size:x-small;margin-left:0.2em"/>
        </attributes>
        <modal uuid="d7316fda-6fe8-4fbc-92c6-5c678ebcf1ab">
          <body uuid="deae2696-899c-4517-9ae4-043fe0ebb971">
            <content xsi:type="org.nasdanika.exec.content:Text" uuid="344d5d5f-9e5f-4bda-b7e0-db5c91d4633e" content="Hover mouse over nodes elements to display tooltips.&#xA;Double-click on nodes to navigate go documentation.&#xA;Left click - rotate.&#xA;Mouse wheel - zoom.&#xA;Right click - pan.&#xA;Drag to rearrange.&#xA;"/>
          </body>
        </modal>
      </decorator>
    </children>
    <decorator uuid="ef54e052-0367-47bc-9397-634154d7c98a" id="e2cce0eb-b61d-4cfa-8d6a-76ef2ff2f398" icon="far fa-question-circle" tooltip="Graphs of package classifiers showing relationships between them">
      <attributes key="style">
        <value xsi:type="org.nasdanika.exec.content:Text" uuid="0992d88b-dbdf-4e76-8497-9a2a496ac4d7" content="vertical-align:super;font-size:x-small;margin-left:0.2em"/>
      </attributes>
