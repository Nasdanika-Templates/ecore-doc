    <children xsi:type="org.nasdanika.models.app:Label" uuid="ebd324ea-aec0-4f62-958c-11803ffc73b3" id="2cf07d2b-a5e2-4565-b59a-ee181c654742" tooltip="With dependencies and sub-packages"/>
    <children xsi:type="org.nasdanika.models.app:Action" uuid="df3da267-f9d9-400e-9dc9-0e709fd4e423" id="bf947ea6-4d3a-431e-8f19-7aa1f2dc011d" text="Default Graph" location="default-graph-with-dependencies-and-subpackages.html">
      <content xsi:type="org.nasdanika.exec.content:Text" uuid="1ca95984-b7b7-43a8-ac80-c5fd2825e97e" content="&lt;div id=&quot;graph-container-26&quot; class=&quot;row&quot; style=&quot;height:70vh;width:100%&quot;>&#xA;&lt;/div>&#xA;&lt;script type=&quot;text/javascript&quot;>&#xA;&#x9;$(document).ready(function() {&#xA;&#x9;&#x9;var dom = document.getElementById(&quot;graph-container-26&quot;);&#xA;&#x9;&#x9;var myChart = echarts.init(dom, null, {&#xA;&#x9;&#x9;&#x9;render: &quot;canvas&quot;,&#xA;&#x9;&#x9;&#x9;useDirtyRect: false&#xA;&#x9;&#x9;});&#xA;&#x9;&#x9;var option = {&quot;legend&quot;:{},&quot;series&quot;:[{&quot;type&quot;:&quot;graph&quot;,&quot;emphasis&quot;:{&quot;focus&quot;:&quot;adjacency&quot;},&quot;data&quot;:[{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&quot;id&quot;:&quot;AbstractList@urn:mypackage&quot;,&quot;name&quot;:&quot;AbstractList&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/AbstractList/index.html&quot;},&quot;x&quot;:843.0110621198274,&quot;y&quot;:246.6594850693456,&quot;category&quot;:0},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EDataType.gif&quot;,&quot;id&quot;:&quot;EJavaObject@http://www.eclipse.org/emf/2002/Ecore&quot;,&quot;name&quot;:&quot;EJavaObject&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;index.html&quot;},&quot;x&quot;:1000.0,&quot;y&quot;:692.2704271925099,&quot;category&quot;:1},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&quot;id&quot;:&quot;ArrayList@urn:mypackage&quot;,&quot;name&quot;:&quot;ArrayList&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/ArrayList/index.html&quot;},&quot;x&quot;:965.2079632887537,&quot;y&quot;:480.1372074778623,&quot;category&quot;:0},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&quot;id&quot;:&quot;AbstractCollection@urn:mypackage&quot;,&quot;name&quot;:&quot;AbstractCollection&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/AbstractCollection/index.html&quot;},&quot;x&quot;:633.5602993973465,&quot;y&quot;:176.3197774559251,&quot;category&quot;:0},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EInterface.gif&quot;,&quot;id&quot;:&quot;Collection@urn:mypackage&quot;,&quot;name&quot;:&quot;Collection&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/Collection/index.html&quot;},&quot;x&quot;:605.6237595232667,&quot;y&quot;:0.0,&quot;category&quot;:0},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EInterface.gif&quot;,&quot;id&quot;:&quot;List@urn:mypackage&quot;,&quot;name&quot;:&quot;List&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/List/index.html&quot;},&quot;x&quot;:808.7306399208303,&quot;y&quot;:15.029785948806936,&quot;category&quot;:0},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EEnum.gif&quot;,&quot;id&quot;:&quot;TimeUnit@urn:mypackage&quot;,&quot;name&quot;:&quot;TimeUnit&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;references/eClassifiers/TimeUnit/index.html&quot;},&quot;x&quot;:0.0,&quot;y&quot;:800.0,&quot;category&quot;:0}],&quot;symbolSize&quot;:20,&quot;roam&quot;:true,&quot;layout&quot;:&quot;none&quot;,&quot;links&quot;:[{&quot;source&quot;:0,&quot;target&quot;:2},{&quot;source&quot;:0,&quot;target&quot;:3},{&quot;source&quot;:0,&quot;target&quot;:5},{&quot;source&quot;:2,&quot;target&quot;:0},{&quot;source&quot;:2,&quot;target&quot;:1},{&quot;source&quot;:3,&quot;target&quot;:0},{&quot;source&quot;:3,&quot;target&quot;:4},{&quot;source&quot;:4,&quot;target&quot;:3},{&quot;source&quot;:4,&quot;target&quot;:5},{&quot;source&quot;:5,&quot;target&quot;:0},{&quot;source&quot;:5,&quot;target&quot;:4}],&quot;categories&quot;:[{&quot;name&quot;:&quot;mypackage&quot;},{&quot;name&quot;:&quot;ecore&quot;}],&quot;draggable&quot;:true,&quot;label&quot;:{&quot;show&quot;:true,&quot;position&quot;:&quot;right&quot;},&quot;lineStyle&quot;:{&quot;color&quot;:&quot;source&quot;,&quot;curveness&quot;:0}}]};&#xA;&#x9;&#x9;option.tooltip = {};&#xA;&#x9;&#x9;option.series[0].tooltip = {&#xA;&#x9;&#x9;&#x9;formatter: function(arg) {&#xA;&#x9;&#x9;&#x9;&#x9;return arg.value ? arg.value.description : null;&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;};&#xA;&#x9;&#x9;myChart.setOption(option);&#xA;&#x9;&#x9;myChart.on(&quot;dblclick&quot;, function(params) {&#xA;&#x9;&#x9;&#x9;if (params.value) {&#xA;&#x9;&#x9;&#x9;&#x9;if (params.value.link) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(params.value.link, &quot;_self&quot;);&#xA;&#x9;&#x9;&#x9;&#x9;} else if (params.value.externalLink) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(params.value.externalLink);&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;});&#xA;&#x9;&#x9;window.addEventListener(&quot;resize&quot;, myChart.resize);&#xA;&#x9;});&#xA;&lt;/script>&#xA;"/>
