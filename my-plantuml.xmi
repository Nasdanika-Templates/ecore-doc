      <children xsi:type="org.nasdanika.models.app:Action" uuid="d54e8532-6348-4810-b6f1-8b0e7c90e225" id="42de9d5d-9e2f-41dd-a2ea-8289b456e543" text="Force Graph" location="force-layout-graph.html">
        <content xsi:type="org.nasdanika.exec.content:Text" uuid="fe68568a-4552-4e97-a0f3-37c7ca462e22" content="&lt;div id=&quot;graph-container-7&quot; class=&quot;row&quot; style=&quot;height:70vh;width:100%&quot;>&#xA;&lt;/div>&#xA;&lt;script type=&quot;text/javascript&quot;>&#xA;&#x9;$(document).ready(function() {&#xA;&#x9;&#x9;var dom = document.getElementById(&quot;graph-container-7&quot;);&#xA;&#x9;&#x9;var myChart = echarts.init(dom, null, {&#xA;&#x9;&#x9;&#x9;render: &quot;canvas&quot;,&#xA;&#x9;&#x9;&#x9;useDirtyRect: false&#xA;&#x9;&#x9;});&#xA;&#x9;&#x9;var option = {&quot;legend&quot;:{},&quot;series&quot;:[{&quot;type&quot;:&quot;graph&quot;,&quot;emphasis&quot;:{&quot;focus&quot;:&quot;adjacency&quot;},&quot;data&quot;:[{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&quot;id&quot;:&quot;AbstractList@urn:mypackage&quot;,&quot;name&quot;:&quot;AbstractList&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;../AbstractList/index.html&quot;},&quot;x&quot;:562.4992461513524,&quot;y&quot;:799.2701707890578,&quot;category&quot;:0},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EClass.gif&quot;,&quot;id&quot;:&quot;AbstractCollection@urn:mypackage&quot;,&quot;name&quot;:&quot;AbstractCollection&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;&quot;},&quot;x&quot;:305.9336207529635,&quot;y&quot;:657.1942974251207,&quot;category&quot;:0},{&quot;symbol&quot;:&quot;image://https://cdn.jsdelivr.net/gh/Nasdanika-Models/ecore@master/graph/web-resources/icons/EInterface.gif&quot;,&quot;id&quot;:&quot;Collection@urn:mypackage&quot;,&quot;name&quot;:&quot;Collection&quot;,&quot;value&quot;:{&quot;externalLink&quot;:&quot;../Collection/index.html&quot;},&quot;x&quot;:48.00957187722689,&quot;y&quot;:514.0435642408455,&quot;category&quot;:0}],&quot;symbolSize&quot;:20,&quot;roam&quot;:true,&quot;layout&quot;:&quot;force&quot;,&quot;links&quot;:[{&quot;source&quot;:0,&quot;target&quot;:1},{&quot;source&quot;:1,&quot;target&quot;:0},{&quot;source&quot;:1,&quot;target&quot;:2},{&quot;source&quot;:2,&quot;target&quot;:1}],&quot;categories&quot;:[{&quot;name&quot;:&quot;mypackage&quot;}],&quot;draggable&quot;:true,&quot;label&quot;:{&quot;show&quot;:true,&quot;position&quot;:&quot;right&quot;},&quot;lineStyle&quot;:{&quot;color&quot;:&quot;source&quot;,&quot;curveness&quot;:0},&quot;force&quot;:{&quot;repulsion&quot;:200,&quot;gravity&quot;:0.1,&quot;edgeLength&quot;:200}}]};&#xA;&#x9;&#x9;option.tooltip = {};&#xA;&#x9;&#x9;option.series[0].tooltip = {&#xA;&#x9;&#x9;&#x9;formatter: function(arg) {&#xA;&#x9;&#x9;&#x9;&#x9;return arg.value ? arg.value.description : null;&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;};&#xA;&#x9;&#x9;myChart.setOption(option);&#xA;&#x9;&#x9;myChart.on(&quot;dblclick&quot;, function(params) {&#xA;&#x9;&#x9;&#x9;if (params.value) {&#xA;&#x9;&#x9;&#x9;&#x9;if (params.value.link) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(params.value.link, &quot;_self&quot;);&#xA;&#x9;&#x9;&#x9;&#x9;} else if (params.value.externalLink) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;window.open(params.value.externalLink);&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;});&#xA;&#x9;&#x9;window.addEventListener(&quot;resize&quot;, myChart.resize);&#xA;&#x9;});&#xA;&lt;/script>&#xA;"/>
        <decorator xsi:type="org.nasdanika.models.app:Link" uuid="b7fbede8-286d-4081-b283-9121aabcf76b" id="72205dd5-fe97-4571-bee9-71caa1d0a4ae" icon="far fa-question-circle" tooltip="A live force-layout graph of this classifier and related classifiers showing relationships between them">
